{
  "schema_version": "kyuubiki.agent-manifest/v1",
  "deployment_mode": "local",
  "agents": [
    {
      "id": "agent-1",
      "host": "127.0.0.1",
      "port": 5001,
      "role": "solver",
      "region": "local",
      "control_mode": "standalone",
      "engine": {
        "lifecycle": "agent_embedded",
        "task_source": "manual_or_sdk",
        "operator_source": "bound_orchestra_fetch",
        "operator_cache_policy": "temporary_execution_cache"
      },
      "tags": ["interactive", "default"]
    },
    {
      "id": "agent-2",
      "host": "127.0.0.1",
      "port": 5002,
      "role": "solver",
      "region": "local",
      "control_mode": "standalone",
      "engine": {
        "lifecycle": "agent_embedded",
        "task_source": "manual_or_sdk",
        "operator_source": "bound_orchestra_fetch",
        "operator_cache_policy": "temporary_execution_cache"
      },
      "tags": ["interactive", "default"]
    }
  ]
}
