{
  "schema_version": "kyuubiki.installation-contract/v1",
  "product_line": "moxi 2.x",
  "shipping_version": "2.2.8",
  "workspace_version": "2.2.8",
  "required_layout": [
    {
      "label": "workspace root",
      "path": ".",
      "required": true
    },
    {
      "label": "runtime temp root",
      "path": "tmp",
      "required": true
    },
    {
      "label": "runtime process state",
      "path": "tmp/run",
      "required": true
    },
    {
      "label": "runtime data state",
      "path": "tmp/data",
      "required": true
    },
    {
      "label": "release staging root",
      "path": "dist",
      "required": true
    },
    {
      "label": "installer-managed runtime payloads",
      "path": "runtimes",
      "required": true
    },
    {
      "label": "platform release staging",
      "path": "dist/{platform}",
      "required": true
    },
    {
      "label": "release snapshots",
      "path": "releases/snapshots",
      "required": true
    },
    {
      "label": "shared brand metadata",
      "path": "assets/brand/brand.json",
      "required": true
    },
    {
      "label": "desktop installer shell",
      "path": "apps/installer-gui",
      "required": true
    },
    {
      "label": "desktop installer brand metadata",
      "path": "apps/installer-gui/ui/assets/brand.json",
      "required": true
    },
    {
      "label": "desktop hub shell",
      "path": "apps/hub-gui",
      "required": true
    },
    {
      "label": "desktop hub brand metadata",
      "path": "apps/hub-gui/ui/assets/brand.json",
      "required": true
    },
    {
      "label": "desktop workbench shell",
      "path": "apps/workbench-gui",
      "required": true
    },
    {
      "label": "desktop workbench brand metadata",
      "path": "apps/workbench-gui/ui/assets/brand.json",
      "required": true
    }
  ],
  "protected_paths": [
    ".env.local",
    "tmp/data",
    "releases/snapshots",
    "apps/installer-gui",
    "apps/hub-gui",
    "apps/workbench-gui"
  ],
  "removable_patterns": [
    ".DS_Store",
    "Thumbs.db",
    "._*",
    "tmp/run/*.pid",
    "tmp/run/*.sock",
    "tmp/run/*.lock",
    "tmp/run/*.tmp"
  ],
  "allowed_dist_children": [
    "macos",
    "linux",
    "windows"
  ],
  "components": [
    {
      "id": "workspace.root",
      "kind": "workspace",
      "version": "2.2.8",
      "owner": "kyuubiki",
      "owned_paths": [
        "."
      ],
      "required_paths": [
        "."
      ],
      "protected_paths": [],
      "removable_patterns": [],
      "visible_rules": [
        {
          "label": "ownership_scope",
          "value": "workspace root sentinel",
          "editable": false,
          "description": "The workspace root component anchors required layout coverage without granting broad cleanup rights."
        }
      ],
      "checks": []
    },
    {
      "id": "brand.shared",
      "kind": "brand-metadata",
      "version": "2.2.8",
      "owner": "kyuubiki",
      "owned_paths": [
        "assets/brand"
      ],
      "required_paths": [
        "assets/brand/brand.json"
      ],
      "protected_paths": [],
      "removable_patterns": [],
      "visible_rules": [
        {
          "label": "release_version",
          "value": "2.2.8",
          "editable": false,
          "description": "Shared brand metadata must expose releaseVersion for every desktop shell copy."
        }
      ],
      "checks": []
    },
    {
      "id": "installer.core",
      "kind": "installer",
      "version": "2.2.8",
      "owner": "kyuubiki-installer",
      "owned_paths": [
        "deploy",
        "workers/rust/crates/installer",
        "dist",
        "runtimes"
      ],
      "required_paths": [
        "deploy/installation-integrity-contract.json",
        "workers/rust/crates/installer",
        "dist",
        "runtimes"
      ],
      "protected_paths": [],
      "removable_patterns": [
        "dist/*/.DS_Store"
      ],
      "visible_rules": [
        {
          "label": "protocol",
          "value": "kyuubiki.component-integrity/v1",
          "editable": false,
          "description": "Installer-owned components must declare path ownership and cleanup behavior."
        }
      ],
      "checks": []
    },
    {
      "id": "desktop.installer",
      "kind": "desktop-shell",
      "version": "2.2.8",
      "owner": "kyuubiki-installer",
      "owned_paths": [
        "apps/installer-gui"
      ],
      "required_paths": [
        "apps/installer-gui",
        "apps/installer-gui/ui/assets/brand.json"
      ],
      "protected_paths": [
        "apps/installer-gui"
      ],
      "removable_patterns": [],
      "visible_rules": [
        {
          "label": "extension_policy",
          "value": "fixed-ui-surface",
          "editable": false,
          "description": "Installer UI is fixed so deployment and repair controls remain stable."
        }
      ],
      "checks": []
    },
    {
      "id": "desktop.hub",
      "kind": "desktop-shell",
      "version": "2.2.8",
      "owner": "kyuubiki-hub",
      "owned_paths": [
        "apps/hub-gui"
      ],
      "required_paths": [
        "apps/hub-gui",
        "apps/hub-gui/ui/assets/brand.json"
      ],
      "protected_paths": [
        "apps/hub-gui"
      ],
      "removable_patterns": [],
      "visible_rules": [
        {
          "label": "extension_policy",
          "value": "fixed-ui-surface",
          "editable": false,
          "description": "Hub UI is part of the stable automation surface and is not user-extensible."
        }
      ],
      "checks": []
    },
    {
      "id": "desktop.workbench",
      "kind": "desktop-shell",
      "version": "2.2.8",
      "owner": "kyuubiki-workbench",
      "owned_paths": [
        "apps/workbench-gui"
      ],
      "required_paths": [
        "apps/workbench-gui",
        "apps/workbench-gui/ui/assets/brand.json"
      ],
      "protected_paths": [
        "apps/workbench-gui"
      ],
      "removable_patterns": [],
      "visible_rules": [
        {
          "label": "extension_policy",
          "value": "fixed-ui-surface",
          "editable": false,
          "description": "Workbench UI is fixed so wasm Python automation has stable controls."
        }
      ],
      "checks": []
    },
    {
      "id": "release.snapshots",
      "kind": "release-history",
      "version": "2.2.8",
      "owner": "kyuubiki-release",
      "owned_paths": [
        "releases/snapshots"
      ],
      "required_paths": [
        "releases/snapshots"
      ],
      "protected_paths": [
        "releases/snapshots"
      ],
      "removable_patterns": [],
      "visible_rules": [
        {
          "label": "retention_policy",
          "value": "protected snapshot history",
          "editable": false,
          "description": "Snapshot records are preserved as lightweight version history and must not be removed by repair."
        }
      ],
      "checks": []
    },
    {
      "id": "runtime.state",
      "kind": "runtime-state",
      "version": "2.2.8",
      "owner": "kyuubiki-runtime",
      "owned_paths": [
        "tmp"
      ],
      "required_paths": [
        "tmp/run",
        "tmp/data"
      ],
      "protected_paths": [
        "tmp/data"
      ],
      "removable_patterns": [
        "tmp/run/*.pid",
        "tmp/run/*.sock",
        "tmp/run/*.lock",
        "tmp/run/*.tmp"
      ],
      "visible_rules": [
        {
          "label": "cleanup_scope",
          "value": "tmp/run only",
          "editable": false,
          "description": "Runtime repair can clean stale process files but must preserve persisted data."
        }
      ],
      "checks": []
    },
    {
      "id": "central.store.api",
      "kind": "central-service",
      "version": "2.2.8",
      "owner": "kyuubiki-central",
      "owned_paths": [
        "apps/web/lib/kyuubiki_web/central_store.ex",
        "apps/web/lib/kyuubiki_web/central_store_router.ex",
        "apps/frontend/src/lib/api/central-store-client.ts",
        "apps/frontend/src/lib/api/central-store-types.ts"
      ],
      "required_paths": [
        "apps/web/lib/kyuubiki_web/central_store.ex",
        "apps/web/lib/kyuubiki_web/central_store_router.ex",
        "apps/frontend/src/lib/api/central-store-client.ts",
        "apps/frontend/src/lib/api/central-store-types.ts"
      ],
      "protected_paths": [],
      "removable_patterns": [],
      "visible_rules": [
        {
          "label": "service_boundary",
          "value": "orchestra-control-plane self-host web surface",
          "editable": false,
          "description": "Central store API is a control-plane service surface and must remain decoupled from Hub, Workbench, and Installer UI internals."
        }
      ],
      "checks": [
        {
          "command": "make check-central-store-contract",
          "purpose": "Verify central store API, frontend client, schema, and docs contract coverage."
        },
        {
          "command": "make build-central-readiness-report",
          "purpose": "Verify central service API/schema/storage readiness remains machine-readable."
        }
      ]
    },
    {
      "id": "central.store.contracts",
      "kind": "central-contracts",
      "version": "2.2.8",
      "owner": "kyuubiki-central",
      "owned_paths": [
        "config/architecture/central-store-contract.json",
        "schemas/central-store-catalog.schema.json",
        "schemas/central-session-policy.schema.json",
        "schemas/central-publish-policy.schema.json",
        "schemas/central-publisher-policy.schema.json",
        "schemas/central-publish-readiness.schema.json",
        "schemas/central-database-policy.schema.json",
        "schemas/central-provenance-policy.schema.json",
        "schemas/central-artifact-admission-policy.schema.json",
        "schemas/central-publish-pipeline.schema.json",
        "schemas/central-database-status.schema.json",
        "schemas/central-readiness-report.schema.json",
        "docs/central-server-components.md"
      ],
      "required_paths": [
        "config/architecture/central-store-contract.json",
        "schemas/central-store-catalog.schema.json",
        "schemas/central-session-policy.schema.json",
        "schemas/central-publish-policy.schema.json",
        "schemas/central-publisher-policy.schema.json",
        "schemas/central-publish-readiness.schema.json",
        "schemas/central-database-policy.schema.json",
        "schemas/central-provenance-policy.schema.json",
        "schemas/central-artifact-admission-policy.schema.json",
        "schemas/central-publish-pipeline.schema.json",
        "schemas/central-database-status.schema.json",
        "schemas/central-readiness-report.schema.json",
        "docs/central-server-components.md"
      ],
      "protected_paths": [],
      "removable_patterns": [],
      "visible_rules": [
        {
          "label": "write_side_policy",
          "value": "read-only preview until publisher, signature, and review gates pass",
          "editable": false,
          "description": "Publisher, artifact admission, provenance, and readiness contracts must remain visible before upload endpoints are enabled."
        }
      ],
      "checks": [
        {
          "command": "make check-central-store-contract",
          "purpose": "Verify central policy schemas and documentation stay aligned."
        },
        {
          "command": "make check-central-readiness-report",
          "purpose": "Verify retained central readiness evidence includes every central API and schema."
        }
      ]
    },
    {
      "id": "central.store.readiness",
      "kind": "central-readiness",
      "version": "2.2.8",
      "owner": "kyuubiki-central",
      "owned_paths": [
        "workers/rust/crates/script-runner/src/central_readiness_report.rs",
        "workers/rust/crates/script-runner/src/central_readiness_report",
        "scripts/build-central-readiness-report.mjs",
        "scripts/check-central-readiness-report.mjs",
        "schemas/central-readiness-report.schema.json"
      ],
      "required_paths": [
        "workers/rust/crates/script-runner/src/central_readiness_report.rs",
        "workers/rust/crates/script-runner/src/central_readiness_report/markdown.rs",
        "workers/rust/crates/script-runner/src/central_readiness_report/publish_pipeline.rs",
        "scripts/build-central-readiness-report.mjs",
        "scripts/check-central-readiness-report.mjs",
        "schemas/central-readiness-report.schema.json"
      ],
      "protected_paths": [],
      "removable_patterns": [],
      "visible_rules": [
        {
          "label": "readiness_surface",
          "value": "native runner with JS compatibility path",
          "editable": false,
          "description": "Central readiness evidence must be generated by the native runner while retained JS scripts stay schema-compatible for older automation."
        },
        {
          "label": "publish_pipeline_evidence",
          "value": "blocked-preview write-side pipeline evidence",
          "editable": false,
          "description": "Publish pipeline stages, blockers, read-only guard, and docs coverage are part of the central readiness report."
        }
      ],
      "checks": [
        {
          "command": "make build-central-readiness-report",
          "purpose": "Generate native central readiness JSON and Markdown evidence."
        },
        {
          "command": "make check-central-readiness-report",
          "purpose": "Validate retained central readiness evidence and publish pipeline contract coverage."
        }
      ]
    }
  ],
  "visible_rules": [
    {
      "category": "cleanup",
      "label": "removable residue allowlist",
      "value": ".DS_Store, Thumbs.db, ._*, tmp/run/*.pid, tmp/run/*.sock, tmp/run/*.lock, tmp/run/*.tmp",
      "editable": false,
      "description": "Only these known cache and stale runtime artifacts are eligible for automatic cleanup."
    },
    {
      "category": "layout",
      "label": "platform release root",
      "value": "dist/{platform}",
      "editable": false,
      "description": "Platform-scoped release staging root tracked by the installer."
    },
    {
      "category": "layout",
      "label": "runtime roots",
      "value": "tmp/, dist/, runtimes/, releases/",
      "editable": false,
      "description": "Standard repo-local roots that every platform install must expose."
    },
    {
      "category": "runtime",
      "label": "embedded runtime manifest",
      "value": "dist/{platform}/manifests/embedded-runtimes.json",
      "editable": false,
      "description": "Installer-managed Elixir/OTP and Node payloads are visible in the staged release manifest before launch."
    },
    {
      "category": "protection",
      "label": "protected paths",
      "value": ".env.local, tmp/data, releases/snapshots, apps/hub-gui, apps/workbench-gui, apps/installer-gui",
      "editable": false,
      "description": "Repair must not remove user environment, runtime data, release snapshots, or desktop shells."
    },
    {
      "category": "version",
      "label": "required development version",
      "value": "2.2.8",
      "editable": false,
      "description": "Desktop shells, workspace packages, and local release descriptors are expected to align to this working version."
    },
    {
      "category": "workflow",
      "label": "repair action",
      "value": "prepare standard layout, then remove allowlisted residue",
      "editable": false,
      "description": "Repair is deterministic and intentionally narrow so it never becomes a hidden cleanup burden."
    }
  ]
}
