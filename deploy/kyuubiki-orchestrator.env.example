# Shared orchestrator defaults for the dedicated Ubuntu lab machine.
# Copy to deploy/kyuubiki-orchestrator.env on the remote host and replace the
# placeholder secrets before enabling the service.

PORT=4000
KYUUBIKI_HTTP_BIND_IP=127.0.0.1
KYUUBIKI_DEPLOYMENT_MODE=distributed
KYUUBIKI_STORAGE_BACKEND=postgres
# Keep real DB passwords outside committed env examples.
DATABASE_URL=ecto://kyuubiki@127.0.0.1:5432/kyuubiki_dev
KYUUBIKI_AGENT_DISCOVERY=static
KYUUBIKI_AGENT_ENDPOINTS=kyuubiki-lab-solver@127.0.0.1:5001
KYUUBIKI_API_TOKEN=replace-me-api-token
KYUUBIKI_CLUSTER_API_TOKEN=replace-me-cluster-token
KYUUBIKI_CLUSTER_ALLOWED_AGENT_IDS=kyuubiki-lab-solver
KYUUBIKI_CLUSTER_REQUIRE_FINGERPRINT=false
KYUUBIKI_PROTECT_READS=true
