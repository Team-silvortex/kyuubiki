# Shared lab-node defaults for the dedicated Ubuntu machine.
# Copy to deploy/kyuubiki-agent.env on the remote host and adjust as needed.

KYUUBIKI_AGENT_PORT=5001
KYUUBIKI_AGENT_ID=kyuubiki-lab-solver
KYUUBIKI_AGENT_ADVERTISE_HOST=kyuubiki-lab.local

# Optional cluster wiring. Leave blank for offline node testing.
KYUUBIKI_ORCHESTRATOR_URL=
KYUUBIKI_CLUSTER_API_TOKEN=
KYUUBIKI_AGENT_FINGERPRINT=
