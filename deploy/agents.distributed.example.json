{
  "schema_version": "kyuubiki.agent-manifest/v1",
  "deployment_mode": "distributed",
  "control_plane": {
    "orchestrator_url": "https://orchestrator.example.com",
    "frontend_url": "https://workbench.example.com"
  },
  "agents": [
    {
      "id": "solver-shanghai-a",
      "host": "10.20.0.11",
      "port": 5001,
      "role": "solver",
      "region": "ap-shanghai",
      "zone": "rack-a",
      "capacity": 8,
      "control_mode": "orch_managed",
      "orch_id": "orchestra/default",
      "engine": {
        "lifecycle": "agent_embedded",
        "task_source": "bound_orchestra_dispatch",
        "operator_source": "bound_orchestra_fetch",
