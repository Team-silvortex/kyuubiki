      },
      "tags": ["cpu", "general"]
    },
    {
      "id": "solver-shanghai-b",
      "host": "10.20.0.12",
      "port": 5001,
      "role": "solver",
      "region": "ap-shanghai",
      "zone": "rack-b",
      "capacity": 8,
      "control_mode": "orch_managed",
      "orch_id": "orchestra/default",
      "engine": {
        "lifecycle": "agent_embedded",
        "task_source": "bound_orchestra_dispatch",
        "operator_source": "bound_orchestra_fetch",
        "operator_cache_policy": "temporary_execution_cache"
      },
      "tags": ["cpu", "general"]
    }
  ]
}
