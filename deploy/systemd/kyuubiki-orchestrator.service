[Unit]
Description=Kyuubiki Orchestrator
After=network-online.target postgresql.service
Wants=network-online.target

[Service]
Type=simple
User={{KYUUBIKI_SERVICE_USER}}
Environment=KYUUBIKI_HOME={{KYUUBIKI_INSTALL_ROOT}}
ExecStart=/bin/sh -lc '. "$KYUUBIKI_HOME/deploy/kyuubiki-orchestrator.env" 2>/dev/null || true; cd "$KYUUBIKI_HOME/apps/web"; exec mix run --no-halt'
Restart=always
RestartSec=2

[Install]
WantedBy=multi-user.target
