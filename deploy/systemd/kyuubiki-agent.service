[Unit]
Description=Kyuubiki Solver Agent
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User={{KYUUBIKI_SERVICE_USER}}
Environment=KYUUBIKI_HOME={{KYUUBIKI_INSTALL_ROOT}}
Environment=RUST_LOG=info
Environment=KYUUBIKI_AGENT_HOST=0.0.0.0
Environment=KYUUBIKI_AGENT_PORT=5001
Environment=KYUUBIKI_AGENT_ID=kyuubiki-lab-solver
Environment=KYUUBIKI_AGENT_ADVERTISE_HOST=kyuubiki-lab.local
EnvironmentFile=-{{KYUUBIKI_INSTALL_ROOT}}/deploy/kyuubiki-agent.env
WorkingDirectory={{KYUUBIKI_INSTALL_ROOT}}
ExecStart={{KYUUBIKI_INSTALL_ROOT}}/workers/rust/target/debug/kyuubiki-cli agent
Restart=always
RestartSec=2

[Install]
WantedBy=multi-user.target
