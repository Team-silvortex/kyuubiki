[Unit]
Description=Kyuubiki Agent Registry Sync
After=network-online.target kyuubiki-orchestrator.service kyuubiki-agent.service
Wants=network-online.target

[Service]
Type=simple
User={{KYUUBIKI_SERVICE_USER}}
Environment=KYUUBIKI_HOME={{KYUUBIKI_INSTALL_ROOT}}
WorkingDirectory={{KYUUBIKI_INSTALL_ROOT}}
ExecStart={{KYUUBIKI_INSTALL_ROOT}}/scripts/kyuubiki agent-registry-sync
Restart=always
RestartSec=2

[Install]
WantedBy=multi-user.target
