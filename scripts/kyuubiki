#!/usr/bin/env sh

set -eu

ROOT_DIR=$(CDPATH= cd -- "$(dirname "$0")/.." && pwd)
LEGACY_ENTRYPOINT="$ROOT_DIR/scripts/kyuubiki-legacy.zsh"
RUNTIME_ENTRYPOINT="$ROOT_DIR/scripts/kyuubiki-runtime.mjs"
RUST_DIR="$ROOT_DIR/workers/rust"
WEB_DIR="$ROOT_DIR/apps/web"
FRONTEND_DIR="$ROOT_DIR/apps/frontend"
HUB_GUI_DIR="$ROOT_DIR/apps/hub-gui"
INSTALLER_GUI_DIR="$ROOT_DIR/apps/installer-gui"
WORKBENCH_GUI_DIR="$ROOT_DIR/apps/workbench-gui"
COMMAND="${1:-help}"

host_platform() {
  case "$(uname -s)" in
    Darwin) printf '%s\n' "macos" ;;
    Linux) printf '%s\n' "linux" ;;
    MINGW*|MSYS*|CYGWIN*) printf '%s\n' "windows" ;;
    *) printf '%s\n' "linux" ;;
  esac
}

run_runtime() {
  cd "$ROOT_DIR"
  exec node "$RUNTIME_ENTRYPOINT" "$@"
}

run_installer() {
  cd "$RUST_DIR"
  exec cargo run -p kyuubiki-installer -- "$@"
}

run_frontend_cli() {
  cd "$FRONTEND_DIR"
  exec node ./scripts/kyuubiki-cli.mjs "$@"
}

run_frontend_build() {
  cd "$FRONTEND_DIR"
  exec npm run build "$@"
}

run_orchestrator_build() {
  cd "$WEB_DIR"
  exec env MIX_ENV=prod mix compile "$@"
}

run_agent_build() {
  cd "$RUST_DIR"
  exec cargo build -p kyuubiki-cli --release "$@"
}

run_web_tests() {
  cd "$WEB_DIR"
  exec mix test "$@"
}

run_rust_tests() {
  cd "$RUST_DIR"
  exec cargo test "$@"
}

run_frontend_tests() {
  cd "$FRONTEND_DIR"
  npm run typecheck
  exec npm run build
}

run_workflow_preflight() {
  cd "$FRONTEND_DIR"
  exec npm run check:workflow-preflight
}

run_benchmark() {
  cd "$RUST_DIR"
  exec cargo run -p kyuubiki-benchmark -- "$@"
}

run_worker() {
  cd "$RUST_DIR"
  exec cargo run -p kyuubiki-cli -- "$@"
}

run_smoke() {
  cd "$WEB_DIR"
  exec mix run -e '
      alias KyuubikiWeb.Jobs.Store
      alias KyuubikiWeb.Workers.MockWorkerAdapter

      {:ok, job} =
        Store.create(%{
          job_id: "job-smoke",
          project_id: "project-smoke",
          simulation_case_id: "case-smoke"
        })

      IO.puts("running smoke flow for #{job.job_id}")
      IO.inspect(MockWorkerAdapter.run_job(job), label: "worker_result")
      IO.inspect(Store.get(job.job_id), label: "final_job")
    '
}

run_sdk_smoke() {
  cd "$ROOT_DIR"
  PYTHONPATH=sdks/python python3 -m unittest discover -s sdks/python/tests
  (cd "$ROOT_DIR/sdks/elixir" && mix test)
  exec cargo test --manifest-path sdks/rust/Cargo.toml --test smoke
}

run_playground_tests() {
  cd "$ROOT_DIR"
  exec node --test apps/web/playground/test/fem.test.mjs "$@"
}

run_orchestrator_foreground() {
  PORT="${1:-4000}"
  MODE="${2:-default}"
  if [ "$MODE" = "local" ]; then
    exec env KYUUBIKI_STORAGE_BACKEND=sqlite SQLITE_DATABASE_PATH="${SQLITE_DATABASE_PATH:-./tmp/data/kyuubiki_dev.sqlite3}" KYUUBIKI_DEPLOYMENT_MODE=local PORT="$PORT" mix -C "$WEB_DIR" run --no-halt
  fi
  if [ "$MODE" = "cloud" ] || [ "$MODE" = "distributed" ]; then
    if [ -z "${DATABASE_URL:-}" ]; then
      echo "DATABASE_URL is required for ${MODE} mode" >&2
      exit 1
    fi
    exec env KYUUBIKI_STORAGE_BACKEND=postgres KYUUBIKI_DEPLOYMENT_MODE="$MODE" PORT="$PORT" mix -C "$WEB_DIR" run --no-halt
  fi
  exec env PORT="$PORT" mix -C "$WEB_DIR" run --no-halt
}

run_agent_foreground() {
  cd "$RUST_DIR"
  exec cargo run -p kyuubiki-cli -- agent --port "${1:-5001}"
}

run_frontend_foreground() {
  cd "$FRONTEND_DIR"
  exec npm run dev
}

run_format() {
  cd "$WEB_DIR"
  mix format
  (cd "$RUST_DIR" && cargo fmt)
}

desktop_app_dir() {
  case "$1" in
    hub-gui) printf '%s\n' "$HUB_GUI_DIR" ;;
    installer-gui) printf '%s\n' "$INSTALLER_GUI_DIR" ;;
    workbench-gui) printf '%s\n' "$WORKBENCH_GUI_DIR" ;;
    *) return 1 ;;
  esac
}

ensure_desktop_cli_ready() {
  APP_DIR=$(desktop_app_dir "$1")
  if [ ! -d "$APP_DIR/node_modules/@tauri-apps/cli" ]; then
    echo "$1 desktop dependencies are missing under $APP_DIR/node_modules" >&2
    echo "run: cd \"$APP_DIR\" && npm install" >&2
    exit 1
  fi
}

run_desktop_dev() {
  APP_DIR=$(desktop_app_dir "$1")
  ensure_desktop_cli_ready "$1"
  cd "$APP_DIR"
  exec npm run tauri:dev
}

stage_release_once() {
  cd "$RUST_DIR"
  cargo run -p kyuubiki-installer -- stage-release "$@"
}

run_desktop_build() {
  APP="$1"
  PLATFORM="${2:-$(host_platform)}"
  APP_DIR=$(desktop_app_dir "$APP")
  ensure_desktop_cli_ready "$APP"
  if [ "$PLATFORM" = "$(host_platform)" ]; then
    cd "$APP_DIR"
    if npm run tauri:build; then
      :
    elif [ "$PLATFORM" = "macos" ] && command -v zsh >/dev/null 2>&1; then
      cd "$ROOT_DIR"
      exec zsh "$LEGACY_ENTRYPOINT" "build-$APP" "$PLATFORM"
    else
      exit 1
    fi
  else
    echo "$APP cross-platform bundle build is not performed on this host; staging ${PLATFORM} desktop manifest instead"
  fi
  stage_release_once "$PLATFORM"
}

run_desktop_stage() {
  PLATFORM="${1:-$(host_platform)}"
  shift || true
  if [ "$PLATFORM" = "all" ]; then
    stage_release_once macos "$@"
    stage_release_once linux "$@"
    stage_release_once windows "$@"
    return
  fi
  stage_release_once "$PLATFORM" "$@"
}

run_package_desktop() {
  PLATFORM="${1:-$(host_platform)}"
  if [ "$PLATFORM" = "all" ]; then
    run_desktop_stage all
    run_desktop_build hub-gui "$(host_platform)"
    run_desktop_build installer-gui "$(host_platform)"
    run_desktop_build workbench-gui "$(host_platform)"
    return
  fi
  run_desktop_stage "$PLATFORM"
  run_desktop_build hub-gui "$PLATFORM"
  run_desktop_build installer-gui "$PLATFORM"
  run_desktop_build workbench-gui "$PLATFORM"
}

desktop_target_apps() {
  printf '%s\n' hub-gui installer-gui workbench-gui
}

desktop_icon_dir() {
  printf '%s\n' "$ROOT_DIR/apps/$1/src-tauri/icons"
}

desktop_manifest_path() {
  printf '%s\n' "$ROOT_DIR/dist/$1/desktop/$2/manifest.json"
}

desktop_bundle_dir() {
  printf '%s\n' "$ROOT_DIR/apps/$1/src-tauri/target/release/bundle"
}

desktop_artifact_manifest_path() {
  printf '%s\n' "$ROOT_DIR/dist/$1/desktop/$2/artifacts.json"
}

desktop_runtime_stage_status() {
  ROOT="$ROOT_DIR/dist/$1"
  [ -d "$ROOT/bin" ] && [ -d "$ROOT/config" ] && [ -d "$ROOT/desktop" ] && printf '%s\n' "present" || printf '%s\n' "missing"
}

desktop_manifest_status() {
  [ -f "$(desktop_manifest_path "$1" "$2")" ] && printf '%s\n' "present" || printf '%s\n' "missing"
}

desktop_icon_status() {
  ICON_DIR=$(desktop_icon_dir "$2")
  case "$1" in
    macos)
      [ -n "$(find "$ICON_DIR" -maxdepth 1 -name '*.png' -print -quit 2>/dev/null)" ] && [ -n "$(find "$ICON_DIR" -maxdepth 1 -name '*.icns' -print -quit 2>/dev/null)" ] && printf '%s\n' "ready (.png + .icns)" || printf '%s\n' "missing macOS icons"
      ;;
    linux)
      [ -n "$(find "$ICON_DIR" -maxdepth 1 -name '*.png' -print -quit 2>/dev/null)" ] && printf '%s\n' "ready (.png)" || printf '%s\n' "missing Linux icons"
      ;;
    windows)
      [ -n "$(find "$ICON_DIR" -maxdepth 1 -name '*.png' -print -quit 2>/dev/null)" ] && [ -n "$(find "$ICON_DIR" -maxdepth 1 -name '*.ico' -print -quit 2>/dev/null)" ] && printf '%s\n' "ready (.png + .ico)" || printf '%s\n' "missing Windows icons"
      ;;
    *)
      printf '%s\n' "unknown"
      ;;
  esac
}

desktop_host_bundle_status() {
  [ -d "$(desktop_bundle_dir "$1")" ] && printf '%s\n' "present" || printf '%s\n' "missing"
}

desktop_host_artifact_status() {
  MANIFEST=$(desktop_artifact_manifest_path "$1" "$2")
  [ -f "$MANIFEST" ] || { printf '%s\n' "missing"; return; }
  COUNT=$(sed -n 's/.*"artifact_count":[[:space:]]*\([0-9][0-9]*\).*/\1/p' "$MANIFEST" | head -n 1)
  COUNT=${COUNT:-0}
  [ "$COUNT" -gt 0 ] && printf 'present (%s)\n' "$COUNT" || printf '%s\n' "empty"
}

verify_manifest_bundle_kind() {
  grep -q "$2" "$1" || {
    echo "missing bundle kind $2 in $1" >&2
    return 1
  }
}

verify_desktop_icons() {
  PLATFORM="$1"
  ICON_DIR=$(desktop_icon_dir "$2")
  case "$PLATFORM" in
    macos) REQUIRED='*.png *.icns' ;;
    linux) REQUIRED='*.png' ;;
    windows) REQUIRED='*.png *.ico' ;;
    *) echo "unsupported platform for icon verification: $PLATFORM" >&2; return 1 ;;
  esac
  for PATTERN in $REQUIRED; do
    [ -n "$(find "$ICON_DIR" -maxdepth 1 -name "$PATTERN" -print -quit 2>/dev/null)" ] || {
      echo "missing $PATTERN icon input for $2 under $ICON_DIR" >&2
      return 1
    }
  done
}

verify_desktop_platform() {
  DESKTOP_ROOT="$ROOT_DIR/dist/$1/desktop"
  [ -d "$DESKTOP_ROOT" ] || { echo "missing staged desktop directory: $DESKTOP_ROOT" >&2; return 1; }
  for APP in $(desktop_target_apps); do
    MANIFEST=$(desktop_manifest_path "$1" "$APP")
    [ -f "$MANIFEST" ] || { echo "missing desktop manifest: $MANIFEST" >&2; return 1; }
    case "$1" in
      macos) verify_manifest_bundle_kind "$MANIFEST" "app" && verify_manifest_bundle_kind "$MANIFEST" "dmg" ;;
      linux) verify_manifest_bundle_kind "$MANIFEST" "appimage" && verify_manifest_bundle_kind "$MANIFEST" "deb" && verify_manifest_bundle_kind "$MANIFEST" "rpm" ;;
      windows) verify_manifest_bundle_kind "$MANIFEST" "msi" && verify_manifest_bundle_kind "$MANIFEST" "nsis" ;;
    esac || return 1
    verify_desktop_icons "$1" "$APP" || return 1
  done
  printf 'desktop release verification passed for %s\n' "$1"
}

print_desktop_status_for_platform() {
  printf '\nplatform: %s\n' "$1"
  printf '  runtime scaffold: %s\n' "$(desktop_runtime_stage_status "$1")"
  for APP in $(desktop_target_apps); do
    printf '  %-16s manifest=%-8s icons=%s\n' "${APP}:" "$(desktop_manifest_status "$1" "$APP")" "$(desktop_icon_status "$1" "$APP")"
    [ "$1" = "$(host_platform)" ] && printf '  %-16s host-bundle=%-8s staged-artifacts=%s\n' "${APP}:" "$(desktop_host_bundle_status "$APP")" "$(desktop_host_artifact_status "$1" "$APP")"
  done
  verify_desktop_platform "$1" >/dev/null 2>&1 && printf '  verification: ready\n' || printf '  verification: needs attention\n'
}

print_desktop_next_steps() {
  HOST=$(host_platform)
  printf '\nnext steps:\n'
  if [ "$1" = "all" ]; then
    printf '%s\n' "  - Stage every platform scaffold: ./scripts/kyuubiki desktop-stage all" "  - Build this host's desktop bundles: ./scripts/kyuubiki desktop-build-host" "  - Verify manifests and icon inputs: ./scripts/kyuubiki desktop-verify all" "  - Review staged bundle manifests under: dist/<host>/desktop/*/artifacts.json"
    return
  fi
  [ "$(desktop_runtime_stage_status "$1")" = "missing" ] && printf '  - Stage runtime + desktop manifests: ./scripts/kyuubiki desktop-stage %s\n' "$1"
  if [ "$1" = "$HOST" ]; then
    printf '%s\n' "  - Build host-native Tauri bundles: ./scripts/kyuubiki desktop-build-host" "  - Run the full host release pass: ./scripts/kyuubiki desktop-release $1" "  - Review staged bundle manifests under: dist/$1/desktop/*/artifacts.json"
  else
    printf '%s\n' "  - This host only stages $1 manifests; build native bundles on a $1 machine" "  - Verify staged rollout descriptors: ./scripts/kyuubiki desktop-verify $1"
  fi
}

run_desktop_status() {
  PLATFORM="${1:-$(host_platform)}"
  printf 'desktop packaging status\n  host platform: %s\n  dist root: %s\n' "$(host_platform)" "$ROOT_DIR/dist"
  if [ "$PLATFORM" = "all" ]; then
    for TARGET in macos linux windows; do
      print_desktop_status_for_platform "$TARGET"
    done
    print_desktop_next_steps all
    return
  fi
  print_desktop_status_for_platform "$PLATFORM"
  print_desktop_next_steps "$PLATFORM"
}

run_desktop_verify() {
  PLATFORM="${1:-$(host_platform)}"
  if [ "$PLATFORM" = "all" ]; then
    verify_desktop_platform macos
    verify_desktop_platform linux
    verify_desktop_platform windows
    return
  fi
  verify_desktop_platform "$PLATFORM"
}

run_legacy() {
  if command -v zsh >/dev/null 2>&1; then
    cd "$ROOT_DIR"
    exec zsh "$LEGACY_ENTRYPOINT" "$@"
  fi

  echo "Command \"$COMMAND\" currently depends on the legacy zsh entrypoint." >&2
  echo "Install zsh or use one of the native cross-platform commands below." >&2
  echo "Native commands: status, start*, restart*, stop, export-db, hot-status, hot-start-*, hot-stop, doctor, validate-env, install, package, package-runtime, cross-platform-audit" >&2
  exit 1
}

print_help() {
  cat <<'EOF'
Unified kyuubiki entrypoint

Native cross-platform commands:
  status
  start | start-local | start-cloud | start-distributed
  restart | restart-local | restart-cloud | restart-distributed
  stop
  export-db [url]
  hot-status
  hot-start-local | hot-start-cloud | hot-start-distributed
  hot-stop
  doctor
  validate-env
  install [installer-command...]
  package | package-runtime
  cross-platform-audit
  project | macro
  build-frontend | build-orchestrator | build-agent
  build-hub-gui | build-installer-gui | build-workbench-gui
  web-test | rust-test | frontend-test | workflow-preflight
  worker | smoke | sdk-smoke | playground-test
  orchestrator | orchestrator-local | orchestrator-cloud | orchestrator-distributed
  agent | frontend
  benchmark | format
  hub-gui-dev | installer-gui-dev | workbench-gui-dev
  desktop-stage
  desktop-status | desktop-verify
  package-desktop
  desktop-upload-remote

Legacy zsh-backed commands:
  desktop-build-host, desktop-release, test, verify,
  hot-local, hot-cloud, hot-distributed, hot-web, hot-agent,
  hot-hub-gui, hot-installer-gui, hot-workbench-gui, playground

Examples:
  ./scripts/kyuubiki status
  ./scripts/kyuubiki desktop-status
  ./scripts/kyuubiki desktop-verify
EOF
}

case "$COMMAND" in
  help|--help|-h)
    print_help
    ;;
  status|start|start-local|start-cloud|start-distributed|restart|restart-local|restart-cloud|restart-distributed|stop|export-db|hot-status|hot-start-local|hot-start-cloud|hot-start-distributed|hot-stop)
    run_runtime "$@"
    ;;
  doctor)
    shift
    run_installer doctor "$@"
    ;;
  validate-env)
    shift
    run_installer validate-env "$@"
    ;;
  cross-platform-audit)
    shift
    run_installer cross-platform-audit "$@"
    ;;
  project|macro)
    shift
    run_frontend_cli "$COMMAND" "$@"
    ;;
  build-frontend)
    shift
    run_frontend_build "$@"
    ;;
  build-orchestrator)
    shift
    run_orchestrator_build "$@"
    ;;
  build-agent)
    shift
    run_agent_build "$@"
    ;;
  build-hub-gui)
    PLATFORM="${2:-$(host_platform)}"
    shift
    shift || true
    run_desktop_build hub-gui "$PLATFORM"
    ;;
  build-installer-gui)
    PLATFORM="${2:-$(host_platform)}"
    shift
    shift || true
    run_desktop_build installer-gui "$PLATFORM"
    ;;
  build-workbench-gui)
    PLATFORM="${2:-$(host_platform)}"
    shift
    shift || true
    run_desktop_build workbench-gui "$PLATFORM"
    ;;
  web-test)
    shift
    run_web_tests "$@"
    ;;
  rust-test)
    shift
    run_rust_tests "$@"
    ;;
  frontend-test)
    shift
    run_frontend_tests "$@"
    ;;
  workflow-preflight)
    shift
    run_workflow_preflight "$@"
    ;;
  worker)
    shift
    run_worker "$@"
    ;;
  smoke)
    shift
    run_smoke "$@"
    ;;
  sdk-smoke)
    shift
    run_sdk_smoke "$@"
    ;;
  playground-test)
    shift
    run_playground_tests "$@"
    ;;
  orchestrator)
    shift
    run_orchestrator_foreground "${1:-4000}" default
    ;;
  orchestrator-local)
    shift
    run_orchestrator_foreground "${1:-4000}" local
    ;;
  orchestrator-cloud)
    shift
    run_orchestrator_foreground "${1:-4000}" cloud
    ;;
  orchestrator-distributed)
    shift
    run_orchestrator_foreground "${1:-4000}" distributed
    ;;
  agent)
    shift
    run_agent_foreground "${1:-5001}"
    ;;
  frontend)
    shift
    run_frontend_foreground "$@"
    ;;
  benchmark)
    shift
    run_benchmark "$@"
    ;;
  format)
    shift
    run_format "$@"
    ;;
  hub-gui-dev)
    shift
    run_desktop_dev hub-gui "$@"
    ;;
  installer-gui-dev)
    shift
    run_desktop_dev installer-gui "$@"
    ;;
  workbench-gui-dev)
    shift
    run_desktop_dev workbench-gui "$@"
    ;;
  desktop-stage)
    PLATFORM="${2:-$(host_platform)}"
    shift
    shift || true
    run_desktop_stage "$PLATFORM" "$@"
    ;;
  desktop-status)
    PLATFORM="${2:-$(host_platform)}"
    shift
    shift || true
    run_desktop_status "$PLATFORM"
    ;;
  desktop-verify)
    PLATFORM="${2:-$(host_platform)}"
    shift
    shift || true
    run_desktop_verify "$PLATFORM"
    ;;
  package-desktop)
    PLATFORM="${2:-$(host_platform)}"
    shift
    shift || true
    run_package_desktop "$PLATFORM"
    ;;
  desktop-upload-remote)
    PLATFORM="${2:-$(host_platform)}"
    shift
    shift || true
    cd "$ROOT_DIR"
    exec bash "$ROOT_DIR/scripts/upload-desktop-release-remote.sh" "$PLATFORM"
    ;;
  install)
    shift
    run_installer "$@"
    ;;
  package|package-runtime)
    shift
    run_installer stage-release "$(host_platform)" "$@"
    ;;
  *)
    run_legacy "$@"
    ;;
esac
