#!/bin/zsh

set -euo pipefail

ROOT_DIR="$(cd "$(dirname "$0")/.." && pwd)"
BASE_PNG="$ROOT_DIR/assets/icons/app/kyuubiki.png"
SWIFT_SCRIPT="$ROOT_DIR/scripts/generate_desktop_icon_badge.swift"
ASSET_DIR="$ROOT_DIR/assets/icons/app"

generate_iconset() {
  local png_path="$1"
  local icns_path="$2"
  local iconset_dir
  iconset_dir="$(mktemp -d /tmp/kyuubiki-iconset.XXXXXX.iconset)"

  sips -z 16 16     "$png_path" --out "$iconset_dir/icon_16x16.png" >/dev/null
  sips -z 32 32     "$png_path" --out "$iconset_dir/icon_16x16@2x.png" >/dev/null
  sips -z 32 32     "$png_path" --out "$iconset_dir/icon_32x32.png" >/dev/null
  sips -z 64 64     "$png_path" --out "$iconset_dir/icon_32x32@2x.png" >/dev/null
  sips -z 128 128   "$png_path" --out "$iconset_dir/icon_128x128.png" >/dev/null
  sips -z 256 256   "$png_path" --out "$iconset_dir/icon_128x128@2x.png" >/dev/null
  sips -z 256 256   "$png_path" --out "$iconset_dir/icon_256x256.png" >/dev/null
  sips -z 512 512   "$png_path" --out "$iconset_dir/icon_256x256@2x.png" >/dev/null
  sips -z 512 512   "$png_path" --out "$iconset_dir/icon_512x512.png" >/dev/null
  cp "$png_path" "$iconset_dir/icon_512x512@2x.png"

  rm -f "$icns_path"
  iconutil --convert icns --output "$icns_path" "$iconset_dir"
  rm -rf "$iconset_dir"
}

generate_variant() {
  local app_key="$1"
  local label="$2"
  local color="$3"
  local target_dir="$4"
  local png_path="$ASSET_DIR/kyuubiki-${app_key}.png"
  local icns_path="$ASSET_DIR/kyuubiki-${app_key}.icns"
  local ico_path="$ASSET_DIR/kyuubiki-${app_key}.ico"
  local ico_source_png="/tmp/kyuubiki-${app_key}-ico.png"

  swift "$SWIFT_SCRIPT" "$BASE_PNG" "$png_path" "$label" "$color"
  generate_iconset "$png_path" "$icns_path"
  sips -z 256 256 "$png_path" --out "$ico_source_png" >/dev/null
  sips -s format ico "$ico_source_png" --out "$ico_path" >/dev/null
  rm -f "$ico_source_png"

  cp "$png_path"  "$target_dir/kyuubiki-app.png"
  cp "$icns_path" "$target_dir/kyuubiki-app.icns"
  cp "$ico_path"  "$target_dir/kyuubiki-app.ico"
}

generate_variant "hub" "H" "#15C4D8" "$ROOT_DIR/apps/hub-gui/src-tauri/icons"
generate_variant "installer" "I" "#F5A623" "$ROOT_DIR/apps/installer-gui/src-tauri/icons"
generate_variant "workbench" "W" "#FF6B57" "$ROOT_DIR/apps/workbench-gui/src-tauri/icons"

echo "generated desktop icon variants:"
echo "  - $ASSET_DIR/kyuubiki-hub.png"
echo "  - $ASSET_DIR/kyuubiki-installer.png"
echo "  - $ASSET_DIR/kyuubiki-workbench.png"
