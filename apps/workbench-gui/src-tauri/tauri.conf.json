{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Kyuubiki Workbench",
  "version": "0.1.0",
  "identifier": "com.kyuubiki.workbench",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Kyuubiki Workbench",
        "width": 1600,
        "height": 980,
        "minWidth": 1180,
        "minHeight": 760,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/kyuubiki-app.png",
      "icons/kyuubiki-app.icns"
    ]
  }
}
