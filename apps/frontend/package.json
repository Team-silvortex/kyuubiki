{
  "name": "kyuubiki-frontend",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "bin": {
    "kyuubiki": "./scripts/kyuubiki-cli.mjs"
  },
  "engines": {
    "node": ">=20.19.2 <25"
  },
  "scripts": {
    "cli": "../../scripts/kyuubiki frontend-cli",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test:unit": "../../scripts/kyuubiki frontend-unit-test",
    "test:unit:headless": "../../scripts/kyuubiki frontend-unit-headless-test",
    "test:unit:headless-live": "../../scripts/kyuubiki frontend-unit-headless-live-test",
    "test:unit:workflow": "../../scripts/kyuubiki frontend-unit-workflow-test",
    "check:file-lines": "cargo run --manifest-path ../../workers/rust/Cargo.toml -p kyuubiki-script-runner -- frontend-file-lines",
    "check:storage-security": "cargo run --manifest-path ../../workers/rust/Cargo.toml -p kyuubiki-script-runner -- frontend-storage-security",
    "check:ui-layout": "../../scripts/kyuubiki frontend-ui-layout-check",
    "check:workflow-preflight": "../../scripts/kyuubiki workflow-preflight",
    "check:workflow-search-layout": "../../scripts/kyuubiki frontend-workflow-search-layout-check",
    "check:workflow-topology": "../../scripts/kyuubiki frontend-workflow-topology-check",
    "typecheck": "../../scripts/kyuubiki frontend-typecheck",
    "benchmark:workflow": "../../scripts/kyuubiki frontend-workflow-benchmark"
  },
  "dependencies": {
    "jszip": "^3.10.1",
    "next": "^15.5.20",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "overrides": {
    "postcss": "8.5.16"
  },
  "devDependencies": {
    "@types/node": "25.5.0",
    "@types/react": "19.2.14",
    "playwright": "^1.60.0",
    "typescript": "6.0.2"
  }
}
