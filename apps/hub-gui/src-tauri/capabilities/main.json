{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "main",
  "description": "Least-privilege IPC surface for the Kyuubiki Hub main window.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "allow-service-status",
    "allow-hot-service-status",
    "allow-read-runtime-log",
    "allow-doctor-report",
    "allow-desktop-status",
    "allow-guarded-mutation-action",
    "allow-project-bundle-inspect",
    "allow-project-bundle-validate",
    "allow-project-bundle-diff",
    "allow-launch-workbench-gui",
    "allow-launch-installer-gui",
    "allow-get-global-language-preference",
    "allow-set-global-language-preference",
    "allow-open-docs-index",
    "allow-open-current-line-doc",
    "allow-open-operations-doc",
    "allow-open-troubleshooting-doc",
    "allow-hub-environment"
  ]
}
