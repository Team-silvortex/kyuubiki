{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Kyuubiki Installer",
  "version": "0.1.0",
  "identifier": "com.kyuubiki.installer",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Kyuubiki Installer",
        "width": 1320,
        "height": 920,
        "minWidth": 1080,
        "minHeight": 760,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
