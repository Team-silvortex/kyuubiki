{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "strict": true,
    "lib": ["DOM", "ES2022"],
    "rootDir": "src",
    "outDir": "ui",
