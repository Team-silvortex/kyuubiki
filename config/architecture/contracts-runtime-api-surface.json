{
  "$schema": "../../schemas/contracts-runtime-api-surface.schema.json",
  "schema_version": "kyuubiki.contracts-runtime-api-surface/v1",
  "module_id": "contracts",
  "runtime_api": {
    "owner": "contracts",
    "contract_families": [
      {
        "id": "frontend-runtime-api",
        "sources": [
          "apps/frontend/src/lib/api/runtime-types.ts",
          "apps/frontend/src/lib/api/workflow-types.ts",
          "apps/frontend/src/lib/api/gui-runtime-capabilities.ts"
        ],
        "client_surfaces": ["workbench-shell", "hub-shell", "installer-shell"],
        "stability_contracts": [
          "typed payloads",
          "capability manifests",
          "backend target resolution"
        ]
      },
      {
        "id": "protocol-runtime-api",
        "sources": [
          "workers/rust/crates/protocol/src/lib.rs",
          "workers/rust/crates/protocol/src/operator_task_ir.rs",
          "workers/rust/crates/protocol/src/solver_execution_capability.rs"
        ],
        "client_surfaces": ["runtime-agent-cli", "sdk-headless", "orchestra-control-plane"],
        "stability_contracts": [
          "TaskIR",
          "solver RPC descriptor",
          "execution capability report"
        ]
      },
      {
        "id": "orchestra-runtime-api",
        "sources": [
          "apps/web/lib/kyuubiki_web/orchestra/engine.ex",
          "apps/web/lib/kyuubiki_web/orchestra/operator_task_executor.ex",
          "apps/web/lib/kyuubiki_web/orchestra/control_plane_surface.ex"
        ],
        "client_surfaces": ["workbench-shell", "sdk-headless", "runtime-agent-cli"],
        "stability_contracts": [
          "workflow graph execution",
          "operator task execution",
          "control-plane surface"
        ]
      },
      {
        "id": "central-store-runtime-api",
        "sources": [
          "apps/web/lib/kyuubiki_web/central_store.ex",
          "apps/web/lib/kyuubiki_web/central_store_router.ex",
          "apps/web/lib/kyuubiki_web/storage/central_database.ex",
          "apps/frontend/src/lib/api/central-store-client.ts",
          "apps/frontend/src/lib/api/central-store-types.ts",
          "config/architecture/central-store-contract.json",
          "schemas/central-store-contract-check.schema.json",
          "schemas/central-store-catalog.schema.json",
          "schemas/central-session-policy.schema.json",
          "schemas/central-publish-policy.schema.json",
          "schemas/central-publish-readiness.schema.json",
          "schemas/central-database-policy.schema.json",
          "schemas/central-provenance-policy.schema.json",
          "schemas/central-database-status.schema.json"
        ],
        "client_surfaces": ["workbench-shell", "hub-shell", "sdk-headless", "installer-shell"],
        "service_surfaces": [
          {
            "id": "central-web-service",
            "module_id": "orchestra-control-plane",
            "kind": "self_host_web"
          }
        ],
        "stability_contracts": [
          "operator store catalog",
          "workflow template store catalog",
          "frontend DSL template store catalog",
          "language-pack distribution",
          "session policy",
          "publish policy",
          "publish readiness",
          "database policy",
          "provenance policy",
          "database status",
          "self-hosted website service surface",
          "central database table contract"
        ]
      }
    ],
    "verification_commands": [
      "./scripts/kyuubiki check-contracts-runtime-api-surface",
      "./scripts/kyuubiki check-central-store-contract",
      "./scripts/kyuubiki check-module-function-matrix"
    ]
  }
}
