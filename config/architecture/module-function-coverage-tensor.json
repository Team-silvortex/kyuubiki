        "required_text": [
          "kyuubiki.operator-qualification-readiness/v1",
          "target_levels",
          "evidence_phases",
          "release_gate_impacts",
          "primary_blocker",
          "preferred_validation_lane"
        ]
      },
      {
        "id": "install-update-validation-contract",
        "files": [
          "deploy/installation-integrity-contract.json",
          "deploy/install-update-disk-hygiene.json",
          "scripts/check-install-update-disk-hygiene.mjs",
          "workers/rust/crates/script-runner/src/install_update_disk_hygiene.rs",
          "workers/rust/crates/script-runner/src/installation_integrity_docs.rs"
        ],
        "required_text": [
          "kyuubiki.installation-contract/v1",
          "kyuubiki.install-update-disk-hygiene/v1",
          "validate_contract",
          "validate_remote_policy",
          "validate_local_retention",
          "validate_update_visibility",
          "protected_paths",
          "removable_roots"
        ]
      }
    ],
    "runtime_api": [
      {
        "id": "contracts-runtime-api-surface",
        "files": [
          "config/architecture/contracts-runtime-api-surface.json",
          "schemas/contracts-runtime-api-surface.schema.json",
          "scripts/check-contracts-runtime-api-surface.mjs"
        ],
        "required_text": [
          "central-web-service",
          "service_surfaces",
          "self_host_web",
          "kyuubiki.contracts-runtime-api-surface/v1"
        ]
      },
      {
        "id": "central-self-host-service-readiness",
        "files": [
          "schemas/central-readiness-report.schema.json",
          "scripts/build-central-readiness-report.mjs",
          "scripts/check-central-readiness-report.mjs"
        ],
        "required_text": [
          "service_surface",
          "central-web-service",
          "orchestra-control-plane"
        ]
      }
    ],
    "deployment_update": [
      {
        "id": "install-update-integrity-contract",
        "files": [
          "deploy/installation-integrity-contract.json",
          "deploy/update-channels.json",
          "deploy/install-update-disk-hygiene.json",
          "releases/update-catalog.json",
          "scripts/check-install-update-disk-hygiene.mjs"
        ],
        "required_text": [
          "kyuubiki.installation-contract/v1",
          "kyuubiki.update-channels/v1",
          "kyuubiki.install-update-disk-hygiene/v1",
          "requires_integrity_contract",
          "allowlisted",
          "same-channel reinstall",
          "remote_artifact_policy",
          "protected_roots"
        ]
      }
    ],
    "security": [
      {
        "id": "gui-credential-boundary-contract",
        "files": [
          "docs/security.md",
          "schemas/gui-runtime-capability-manifest.schema.json",
          "workers/rust/crates/script-runner/src/frontend_checks.rs",
          "workers/rust/crates/script-runner/src/gui_runtime_capability_contract.rs",
          "scripts/check-gui-runtime-capability-contract.mjs"
        ],
        "required_text": [
          ".kyuubiki/credentials",
          "credential_surface",
          "product_owned_static_ui",
          "user_extensible_ui_allowed",
          "Do not read or write token, password, credential, API key, or secret-shaped values through browser storage.",
          "GUI code should select bindings by declared capability"
        ]
      }
    ]
  },
