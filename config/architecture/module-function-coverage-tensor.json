{
  "schema_version": "kyuubiki.module-function-coverage-tensor/v1",
  "version_line": "moxi 2.0.x",
  "topology": "config/architecture/module-topology.json",
  "matrix": "config/architecture/module-function-coverage-matrix.json",
  "depth_axes": {
    "required": "Whether the module/paradigm pair is required by the module-function matrix.",
    "status": "The direct matrix coverage state for the module/paradigm pair.",
    "benchmark_evidence": "Relevant benchmark lanes and lane test commands from the module topology.",
    "security_evidence": "Relevant security lanes and lane test commands from the module topology.",
    "contract_evidence": "Required schemas, config contracts, and text anchors that prove a paradigm has machine-readable release gates.",
    "gap": "Derived action level for locating weak, thinly evidenced, or uncovered coordinates."
  },
  "paradigm_contract_evidence": {
    "product_surface": [
      {
        "id": "gui-product-surface-automation-contract",
        "files": [
          "docs/ui-automation-contract.json",
          "schemas/gui-runtime-capability-manifest.schema.json",
          "schemas/examples.gui-runtime-capability-manifest.json",
          "workers/rust/crates/script-runner/src/ui_automation_contract.rs",
          "workers/rust/crates/script-runner/src/gui_runtime_capability_contract.rs"
        ],
        "required_text": [
          "productOwned",
          "userExtensible",
          "product_owned_static_ui",
          "wasm_python_stability_required",
          "user_extensible_ui_allowed",
          "headless_sdk_parity_required",
          "WORKBENCH_UI_AUTOMATION_CONTRACT_VERSION = 1"
        ]
      }
    ],
    "validation": [
      {
        "id": "operator-qualification-readiness",
        "files": [
          "config/operator-qualification-roadmap.json",
          "config/operator-qualification-evidence-kits.json",
          "schemas/operator-qualification-readiness.schema.json",
          "scripts/build-operator-qualification-readiness.mjs",
          "scripts/check-operator-qualification-readiness.mjs"
