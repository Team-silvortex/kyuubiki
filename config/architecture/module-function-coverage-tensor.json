{
  "schema_version": "kyuubiki.module-function-coverage-tensor/v1",
  "version_line": "tamamono 1.20.x",
  "topology": "config/architecture/module-topology.json",
  "matrix": "config/architecture/module-function-coverage-matrix.json",
  "depth_axes": {
    "required": "Whether the module/paradigm pair is required by the module-function matrix.",
    "status": "The direct matrix coverage state for the module/paradigm pair.",
    "benchmark_evidence": "Relevant benchmark lanes and lane test commands from the module topology.",
    "security_evidence": "Relevant security lanes and lane test commands from the module topology.",
    "contract_evidence": "Required schemas, config contracts, and text anchors that prove a paradigm has machine-readable release gates.",
    "gap": "Derived action level for locating weak, thinly evidenced, or uncovered coordinates."
  },
  "paradigm_contract_evidence": {
    "validation": [
      {
        "id": "operator-qualification-readiness",
        "files": [
          "config/operator-qualification-roadmap.json",
          "config/operator-qualification-evidence-kits.json",
          "schemas/operator-qualification-readiness.schema.json",
          "scripts/build-operator-qualification-readiness.mjs",
          "scripts/check-operator-qualification-readiness.mjs"
        ],
        "required_text": [
          "kyuubiki.operator-qualification-readiness/v1",
          "target_levels",
          "evidence_phases",
          "release_gate_impacts",
          "primary_blocker",
          "preferred_validation_lane"
        ]
      }
    ],
    "runtime_api": [
      {
        "id": "contracts-runtime-api-surface",
        "files": [
          "config/architecture/contracts-runtime-api-surface.json",
          "schemas/contracts-runtime-api-surface.schema.json",
          "scripts/check-contracts-runtime-api-surface.mjs"
        ],
        "required_text": [
          "central-web-service",
          "service_surfaces",
          "self_host_web",
          "kyuubiki.contracts-runtime-api-surface/v1"
        ]
      },
      {
        "id": "central-self-host-service-readiness",
        "files": [
          "schemas/central-readiness-report.schema.json",
          "scripts/build-central-readiness-report.mjs",
          "scripts/check-central-readiness-report.mjs"
        ],
        "required_text": [
          "service_surface",
          "central-web-service",
          "orchestra-control-plane"
        ]
      }
    ]
  },
  "paradigm_lanes": {
    "product_surface": {
      "benchmark": [
        "ui_startup"
      ],
      "security": [
        "ui_boundary"
      ]
    },
    "runtime_api": {
      "benchmark": [
        "control_plane",
        "runtime_solver",
        "mesh",
        "sdk_headless"
      ],
      "security": [
        "api_auth",
        "data_contract"
      ]
    },
    "solver_execution": {
      "benchmark": [
        "runtime_solver"
      ],
      "security": [
        "runtime_sandbox",
        "data_contract"
      ]
    },
    "workflow_composition": {
      "benchmark": [
        "workflow_catalog",
        "sdk_headless"
      ],
      "security": [
        "data_contract",
        "runtime_sandbox"
      ]
    },
    "validation": {
      "benchmark": [
        "runtime_solver",
        "sdk_headless"
      ],
      "security": [
        "data_contract",
        "runtime_sandbox"
      ]
    },
    "benchmark": {
      "benchmark": [
        "ui_startup",
        "workflow_catalog",
        "control_plane",
        "runtime_solver",
        "mesh",
        "sdk_headless",
        "installer_release"
      ],
      "security": []
    },
    "security": {
      "benchmark": [],
      "security": [
        "ui_boundary",
        "api_auth",
        "runtime_sandbox",
        "supply_chain",
        "credential_storage",
        "remote_deploy",
        "data_contract"
      ]
    },
    "persistence_provenance": {
      "benchmark": [
        "control_plane",
        "workflow_catalog",
        "installer_release"
      ],
      "security": [
        "data_contract",
        "supply_chain"
      ]
    },
    "deployment_update": {
      "benchmark": [
        "installer_release",
        "mesh"
      ],
      "security": [
        "remote_deploy",
        "supply_chain",
        "credential_storage"
      ]
    },
    "sdk_headless": {
      "benchmark": [
        "sdk_headless",
        "runtime_solver"
      ],
      "security": [
        "api_auth",
        "credential_storage",
        "data_contract"
      ]
    }
  },
  "gap_policy": {
    "covered": "ok",
    "required_partial": "weak",
    "required_missing_or_planned": "required_gap",
    "required_covered_without_evidence": "weak_evidence",
    "optional_partial": "watch",
    "optional_planned": "planned",
    "not_applicable": "not_applicable"
  }
}
