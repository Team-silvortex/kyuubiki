{
  "schema_version": "kyuubiki.gui-runtime-capability-manifest/v1",
  "surface_id": "hub.default",
  "surface_kind": "hub",
  "ui_ownership": "product_owned_static_ui",
  "automation_contract": {
    "selector_contract_id": "kyuubiki.hub-ui-automation/v1",
    "wasm_python_stability_required": true,
    "user_extensible_ui_allowed": false
  },
  "runtime_bindings": [
    {
      "binding_id": "workload-control-plane",
      "target_kind": "orchestra",
      "binding_mode": "http_control_plane",
      "required_capabilities": [
        "workload.list",
        "runtime.target.observe",
        "job.summary.read"
      ],
      "optional_capabilities": [
        "agent.registry.observe",
        "log.summary.read",
        "update.status.read"
      ],
      "headless_sdk_parity_required": true,
      "mobile_supported": true,
      "credential_surface": "session_token",
      "notes": "Hub observes and launches workloads through a control plane; it does not own solver execution."
    },
    {
      "binding_id": "offline-workload-catalog",
      "target_kind": "offline_bundle",
      "binding_mode": "read_only",
      "required_capabilities": [
        "workload.catalog.read",
        "project.recent.read"
      ],
      "optional_capabilities": [
        "diagnostics.export"
      ],
      "headless_sdk_parity_required": true,
      "mobile_supported": true,
      "credential_surface": "none",
      "notes": "Hub may show local or cached workload metadata when no runtime is reachable."
    }
  ],
  "degraded_modes": [
    {
      "mode": "catalog_only",
      "trigger": "No orchestrator or compatible workload backend is reachable.",
      "allowed_actions": [
        "open recent metadata",
        "inspect cached workload catalog",
        "export diagnostics"
      ],
      "blocked_actions": [
        "submit workflow",
        "change agent binding"
      ]
    }
  ]
}
