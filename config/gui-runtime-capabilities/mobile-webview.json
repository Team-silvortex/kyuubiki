{
  "schema_version": "kyuubiki.gui-runtime-capability-manifest/v1",
  "surface_id": "mobile-webview.default",
  "surface_kind": "mobile_webview",
  "ui_ownership": "product_owned_static_ui",
  "automation_contract": {
    "selector_contract_id": "kyuubiki.mobile-webview-ui-automation/v1",
    "wasm_python_stability_required": true,
    "user_extensible_ui_allowed": false
  },
  "runtime_bindings": [
    {
      "binding_id": "remote-control-plane",
      "target_kind": "orchestra",
      "binding_mode": "http_control_plane",
      "required_capabilities": [
        "workflow.submit",
        "job.poll",
        "result.chunk.read"
      ],
      "optional_capabilities": [
        "agent.registry.observe",
        "project.bundle.open",
        "credential.handle.request"
      ],
      "headless_sdk_parity_required": true,
      "mobile_supported": true,
      "credential_surface": "device_keystore",
      "notes": "Mobile GUI is a remote-control client; credentials stay behind native secure-storage handles."
    },
    {
      "binding_id": "offline-result-review",
      "target_kind": "offline_bundle",
      "binding_mode": "read_only",
      "required_capabilities": [
        "project.bundle.open",
        "result.inspect"
      ],
      "optional_capabilities": [
        "report.share"
      ],
      "headless_sdk_parity_required": true,
      "mobile_supported": true,
      "credential_surface": "none",
      "notes": "Mobile may inspect portable bundles without hosting any local runtime."
    }
  ],
  "degraded_modes": [
    {
      "mode": "remote_required",
      "trigger": "No remote backend target is configured or reachable.",
      "allowed_actions": [
        "open local bundle",
        "edit draft metadata",
        "configure remote backend"
      ],
      "blocked_actions": [
        "host orchestra",
        "host agent",
        "install runtime",
        "use localhost backend"
      ]
    }
  ]
}
