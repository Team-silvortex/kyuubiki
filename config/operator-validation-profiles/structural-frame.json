{
  "schema_version": "kyuubiki.operator-validation-profiles/v1",
  "version_line": "moxi 2.0.x",
  "domain": "structural",
  "profiles": [
    {
      "profile_id": "frame-3d-closed-form",
      "profile_role": "release_candidate",
      "qualification_candidate_id": "frame-3d-closed-form",
      "trust_goal": "qualification_input",
      "operators": [
        "solve.frame_3d"
      ],
      "validation_methods": [
        "cantilever_closed_form",
        "section_stress_balance",
        "strain_energy_balance"
      ],
      "formal_invariants": [
        "fixed_root_translation_rotation_are_zero",
        "tip_displacement_matches_euler_bernoulli_cantilever",
        "tip_rotation_matches_cantilever_slope",
        "end_moment_and_bending_stress_match_section_formula",
        "strain_energy_matches_half_load_displacement_work"
      ],
      "evidence_paths": [
        "config/operator-reliability/structural.json",
        "docs/operator-reliability.md",
        "evidence/operator-qualification/frame-3d-closed-form.md",
        "workers/rust/crates/solver/tests/frame_3d_review.rs",
        "workers/rust/crates/solver/tests/frame_3d_closed_form.rs",
        "workers/rust/crates/solver/tests/frame_input_reliability.rs"
      ],
      "commands": [
        {
          "id": "frame-3d-review",
          "kind": "cross_check",
          "command": "cd workers/rust && cargo test -p kyuubiki-solver --test frame_3d_review -- --nocapture"
        },
        {
          "id": "frame-3d-closed-form",
          "kind": "cross_check",
          "command": "cd workers/rust && cargo test -p kyuubiki-solver --test frame_3d_closed_form -- --nocapture"
        },
        {
          "id": "frame-input-reliability",
          "kind": "boundary_regression",
          "command": "cd workers/rust && cargo test -p kyuubiki-solver --test frame_input_reliability -- --nocapture"
        }
      ]
    },
    {
      "profile_id": "buckling-beam-1d-screening",
      "profile_role": "component_profile",
      "qualification_candidate_id": "buckling-beam-1d",
      "trust_goal": "screening_validation",
      "operators": [
        "solve.buckling_beam_1d"
      ],
      "validation_methods": [
        "euler_column_closed_form",
        "mesh_convergence",
        "dimensional_scaling",
        "input_boundary_rejection"
      ],
      "formal_invariants": [
        "pinned_column_converges_to_pi_squared_ei_over_l_squared",
        "critical_factor_scales_with_ei_over_reference_force_l_squared",
        "mode_shape_is_normalized",
        "invalid_topology_and_non_positive_properties_are_rejected"
      ],
      "evidence_paths": [
        "evidence/operator-screening/buckling-beam-1d-linear-eigenvalue.md",
        "workers/rust/crates/solver/tests/buckling_beam_1d_closed_form.rs",
        "workers/rust/crates/solver/tests/buckling_beam_1d_input_reliability.rs",
        "workers/rust/crates/engine/tests/buckling_beam_workflow.rs"
      ],
      "commands": [
        {
          "id": "buckling-beam-closed-form",
          "kind": "analytic",
          "command": "cd workers/rust && cargo test -p kyuubiki-solver --test buckling_beam_1d_closed_form -- --nocapture"
        },
        {
          "id": "buckling-beam-input-reliability",
          "kind": "boundary_regression",
          "command": "cd workers/rust && cargo test -p kyuubiki-solver --test buckling_beam_1d_input_reliability -- --nocapture"
        },
        {
          "id": "buckling-beam-workflow-route",
          "kind": "contract",
          "command": "cd workers/rust && cargo test -p kyuubiki-engine --test buckling_beam_workflow -- --nocapture"
        }
      ]
    }
  ]
}
