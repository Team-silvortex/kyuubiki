{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kyuubiki.local/schemas/operator-reliability-shard.schema.json",
  "title": "Kyuubiki Operator Reliability Shard",
  "type": "object",
  "required": ["schema_version", "domain", "operators"],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "const": "kyuubiki.operator-reliability-shard/v1" },
    "domain": { "type": "string", "minLength": 1 },
    "operators": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "operator_id",
          "benchmark_template",
          "domain",
          "coverage_level",
          "evidence",
          "limits"
        ],
        "additionalProperties": false,
        "properties": {
          "operator_id": { "type": "string", "pattern": "^solve\\.[a-z0-9_]+$" },
          "benchmark_template": { "type": "string", "minLength": 1 },
          "domain": { "type": "string", "minLength": 1 },
          "coverage_level": { "enum": ["smoke", "baseline", "review", "qualification"] },
          "evidence": {
            "type": "object",
            "required": ["benchmark_matrix", "headless_workflow", "tests"],
            "additionalProperties": false,
            "properties": {
              "benchmark_matrix": { "type": "string", "minLength": 1 },
              "headless_workflow": { "type": "boolean" },
              "tests": {
                "type": "array",
                "items": { "type": "string", "minLength": 1 },
                "minItems": 1,
                "uniqueItems": true
              },
              "accuracy_baseline": { "type": "string", "minLength": 1 },
              "reliability_suite": { "type": "string", "minLength": 1 },
              "review": {
                "type": "object",
                "required": ["assumptions", "boundary_checks", "diagnostics", "tests"],
                "additionalProperties": false,
                "properties": {
                  "assumptions": {
                    "type": "array",
                    "items": { "type": "string", "minLength": 1 },
                    "minItems": 1,
                    "uniqueItems": true
                  },
                  "boundary_checks": {
                    "type": "array",
                    "items": { "type": "string", "minLength": 1 },
                    "minItems": 1,
                    "uniqueItems": true
                  },
                  "diagnostics": {
                    "type": "array",
                    "items": { "type": "string", "minLength": 1 },
                    "minItems": 1,
                    "uniqueItems": true
                  },
                  "tests": {
                    "type": "array",
                    "items": { "type": "string", "minLength": 1 },
                    "minItems": 1,
                    "uniqueItems": true
                  },
                  "scope_notes": {
                    "type": "array",
                    "items": { "type": "string", "minLength": 1 },
                    "minItems": 1,
                    "uniqueItems": true
                  },
                  "tolerance_notes": {
                    "type": "array",
                    "items": { "type": "string", "minLength": 1 },
                    "minItems": 1,
                    "uniqueItems": true
                  },
                  "material_notes": {
                    "type": "array",
                    "items": { "type": "string", "minLength": 1 },
                    "minItems": 1,
                    "uniqueItems": true
                  }
                }
              },
              "qualification": {
                "type": "object",
                "required": [
                  "validation_sources",
                  "convergence_checks",
                  "provenance",
                  "release_gates",
                  "tests"
                ],
                "additionalProperties": false,
                "properties": {
                  "validation_sources": {
                    "type": "array",
                    "items": { "type": "string", "minLength": 1 },
                    "minItems": 1,
                    "uniqueItems": true
                  },
                  "convergence_checks": {
                    "type": "array",
                    "items": { "type": "string", "minLength": 1 },
                    "minItems": 1,
                    "uniqueItems": true
                  },
                  "provenance": {
                    "type": "array",
                    "items": { "type": "string", "minLength": 1 },
                    "minItems": 1,
                    "uniqueItems": true
                  },
                  "release_gates": {
                    "type": "array",
                    "items": { "type": "string", "minLength": 1 },
                    "minItems": 1,
                    "uniqueItems": true
                  },
                  "tests": {
                    "type": "array",
                    "items": { "type": "string", "minLength": 1 },
                    "minItems": 1,
                    "uniqueItems": true
                  }
                }
              }
            }
          },
          "limits": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 },
            "minItems": 1,
            "uniqueItems": true
          }
        }
      }
    }
  }
}
