{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kyuubiki.local/schemas/job.schema.json",
  "title": "Job",
  "description": "Durable FEM job metadata shared between orchestration and workers.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "job_id",
    "project_id",
    "simulation_case_id",
    "status",
    "progress",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "job_id": {
      "type": "string",
      "format": "uuid"
    },
    "project_id": {
      "type": "string",
      "format": "uuid"
    },
    "model_version_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "simulation_case_id": {
      "type": "string",
      "format": "uuid"
    },
    "status": {
      "type": "string",
      "enum": [
        "queued",
        "preprocessing",
        "partitioning",
        "solving",
        "postprocessing",
        "completed",
        "failed",
        "cancelled"
      ]
    },
    "status_detail": {
      "type": [
        "object",
        "null"
      ],
      "additionalProperties": false,
      "required": [
        "lifecycle",
        "active",
        "terminal",
        "recoverable"
      ],
      "properties": {
        "lifecycle": {
          "type": "string",
          "enum": [
            "active",
            "terminal"
          ]
        },
        "active": {
          "type": "boolean"
        },
        "terminal": {
          "type": "boolean"
        },
        "failure_class": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "watchdog_stalled",
            "watchdog_timeout",
            "execution_timeout",
            "runtime_failure",
            "operator_cancelled",
            "cancelled",
            null
          ]
        },
        "recoverable": {
          "type": "boolean"
        }
      }
    },
    "progress": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "residual": {
      "type": [
        "number",
        "null"
      ]
    },
    "iteration": {
      "type": [
        "integer",
        "null"
      ],
      "minimum": 0
    },
    "worker_id": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
