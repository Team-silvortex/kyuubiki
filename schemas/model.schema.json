{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kyuubiki.local/schemas/model.schema.json",
  "title": "Kyuubiki Study Model",
  "description": "Versioned import/export model contract for browser-side study setup.",
  "oneOf": [
    { "$ref": "#/$defs/axialBarModelV1" },
    { "$ref": "#/$defs/truss2dModelV1" },
    { "$ref": "#/$defs/truss3dModelV1" },
    { "$ref": "#/$defs/planeTriangle2dModelV1" }
  ],
  "$defs": {
    "baseModelV1": {
      "type": "object",
      "required": ["model_schema_version", "kind", "name"],
      "properties": {
        "model_schema_version": {
          "type": "string",
          "const": "kyuubiki.model/v1"
        },
        "kind": {
          "type": "string"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "material": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "axialBarModelV1": {
      "allOf": [
        { "$ref": "#/$defs/baseModelV1" },
        {
          "type": "object",
          "required": [
            "model_schema_version",
            "kind",
            "name",
            "length",
            "area",
            "elements",
            "tip_force",
            "youngs_modulus_gpa"
          ],
          "properties": {
            "model_schema_version": {
              "type": "string",
              "const": "kyuubiki.model/v1"
            },
            "kind": {
              "type": "string",
              "const": "axial_bar_1d"
            },
            "name": {
              "type": "string",
              "minLength": 1
            },
            "material": {
              "type": "string",
              "minLength": 1
            },
            "length": {
              "type": "number",
              "exclusiveMinimum": 0
            },
            "area": {
              "type": "number",
              "exclusiveMinimum": 0
            },
            "elements": {
              "type": "integer",
              "minimum": 1
            },
            "tip_force": {
              "type": "number"
            },
            "youngs_modulus_gpa": {
              "type": "number",
              "exclusiveMinimum": 0
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "trussNodeV1": {
      "type": "object",
      "required": ["id", "x", "y", "fix_x", "fix_y", "load_x", "load_y"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "x": { "type": "number" },
        "y": { "type": "number" },
        "fix_x": { "type": "boolean" },
        "fix_y": { "type": "boolean" },
        "load_x": { "type": "number" },
        "load_y": { "type": "number" }
      },
      "additionalProperties": false
    },
    "trussElementV1": {
      "type": "object",
      "required": ["id", "node_i", "node_j", "area", "youngs_modulus"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "node_i": { "type": "integer", "minimum": 0 },
        "node_j": { "type": "integer", "minimum": 0 },
        "area": { "type": "number", "exclusiveMinimum": 0 },
        "youngs_modulus": { "type": "number", "exclusiveMinimum": 0 }
      },
      "additionalProperties": false
    },
    "truss2dModelV1": {
      "allOf": [
        { "$ref": "#/$defs/baseModelV1" },
        {
          "type": "object",
          "required": [
            "model_schema_version",
            "kind",
            "name",
            "youngs_modulus_gpa",
            "nodes",
            "elements"
          ],
          "properties": {
            "model_schema_version": {
              "type": "string",
              "const": "kyuubiki.model/v1"
            },
            "kind": {
              "type": "string",
              "const": "truss_2d"
            },
            "name": {
              "type": "string",
              "minLength": 1
            },
            "material": {
              "type": "string",
              "minLength": 1
            },
            "youngs_modulus_gpa": {
              "type": "number",
              "exclusiveMinimum": 0
            },
            "nodes": {
              "type": "array",
              "minItems": 2,
              "items": {
                "$ref": "#/$defs/trussNodeV1"
              }
            },
            "elements": {
              "type": "array",
              "minItems": 1,
              "items": {
                "$ref": "#/$defs/trussElementV1"
              }
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "truss3dNodeV1": {
      "type": "object",
      "required": ["id", "x", "y", "z", "fix_x", "fix_y", "fix_z", "load_x", "load_y", "load_z"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "x": { "type": "number" },
        "y": { "type": "number" },
        "z": { "type": "number" },
        "fix_x": { "type": "boolean" },
        "fix_y": { "type": "boolean" },
        "fix_z": { "type": "boolean" },
        "load_x": { "type": "number" },
        "load_y": { "type": "number" },
        "load_z": { "type": "number" }
      },
      "additionalProperties": false
    },
    "truss3dElementV1": {
      "type": "object",
      "required": ["id", "node_i", "node_j", "area", "youngs_modulus"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "node_i": { "type": "integer", "minimum": 0 },
        "node_j": { "type": "integer", "minimum": 0 },
        "area": { "type": "number", "exclusiveMinimum": 0 },
        "youngs_modulus": { "type": "number", "exclusiveMinimum": 0 }
      },
      "additionalProperties": false
    },
    "truss3dModelV1": {
      "allOf": [
        { "$ref": "#/$defs/baseModelV1" },
        {
          "type": "object",
          "required": [
            "model_schema_version",
            "kind",
            "name",
            "youngs_modulus_gpa",
            "nodes",
            "elements"
          ],
          "properties": {
            "model_schema_version": {
              "type": "string",
              "const": "kyuubiki.model/v1"
            },
            "kind": {
              "type": "string",
              "const": "truss_3d"
            },
            "name": {
              "type": "string",
              "minLength": 1
            },
            "material": {
              "type": "string",
              "minLength": 1
            },
            "youngs_modulus_gpa": {
              "type": "number",
              "exclusiveMinimum": 0
            },
            "nodes": {
              "type": "array",
              "minItems": 3,
              "items": {
                "$ref": "#/$defs/truss3dNodeV1"
              }
            },
            "elements": {
              "type": "array",
              "minItems": 1,
              "items": {
                "$ref": "#/$defs/truss3dElementV1"
              }
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "planeNodeV1": {
      "type": "object",
      "required": ["id", "x", "y", "fix_x", "fix_y", "load_x", "load_y"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "x": { "type": "number" },
        "y": { "type": "number" },
        "fix_x": { "type": "boolean" },
        "fix_y": { "type": "boolean" },
        "load_x": { "type": "number" },
        "load_y": { "type": "number" }
      },
      "additionalProperties": false
    },
    "planeTriangleElementV1": {
      "type": "object",
      "required": ["id", "node_i", "node_j", "node_k", "thickness", "youngs_modulus", "poisson_ratio"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "node_i": { "type": "integer", "minimum": 0 },
        "node_j": { "type": "integer", "minimum": 0 },
        "node_k": { "type": "integer", "minimum": 0 },
        "thickness": { "type": "number", "exclusiveMinimum": 0 },
        "youngs_modulus": { "type": "number", "exclusiveMinimum": 0 },
        "poisson_ratio": { "type": "number" }
      },
      "additionalProperties": false
    },
    "planeTriangle2dModelV1": {
      "allOf": [
        { "$ref": "#/$defs/baseModelV1" },
        {
          "type": "object",
          "required": [
            "model_schema_version",
            "kind",
            "name",
            "youngs_modulus_gpa",
            "nodes",
            "elements"
          ],
          "properties": {
            "model_schema_version": {
              "type": "string",
              "const": "kyuubiki.model/v1"
            },
            "kind": {
              "type": "string",
              "const": "plane_triangle_2d"
            },
            "name": {
              "type": "string",
              "minLength": 1
            },
            "material": {
              "type": "string",
              "minLength": 1
            },
            "youngs_modulus_gpa": {
              "type": "number",
              "exclusiveMinimum": 0
            },
            "nodes": {
              "type": "array",
              "minItems": 3,
              "items": {
                "$ref": "#/$defs/planeNodeV1"
              }
            },
            "elements": {
              "type": "array",
              "minItems": 1,
              "items": {
                "$ref": "#/$defs/planeTriangleElementV1"
              }
            }
          },
          "additionalProperties": false
        }
      ]
    }
  }
}
