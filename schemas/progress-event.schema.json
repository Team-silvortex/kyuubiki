{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kyuubiki.local/schemas/progress-event.schema.json",
  "title": "ProgressEvent",
  "description": "Streamed status event emitted by workers during job execution.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "job_id",
    "stage",
    "progress"
  ],
  "properties": {
    "job_id": {
      "type": "string",
      "format": "uuid"
    },
    "stage": {
      "type": "string",
      "enum": [
        "queued",
        "preprocessing",
        "partitioning",
        "solving",
        "postprocessing",
        "completed",
        "failed",
        "cancelled"
      ]
    },
    "progress": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "residual": {
      "type": [
        "number",
        "null"
      ]
    },
    "iteration": {
      "type": [
        "integer",
        "null"
      ],
      "minimum": 0
    },
    "peak_memory": {
      "type": [
        "integer",
        "null"
      ],
      "minimum": 0
    },
    "message": {
      "type": [
        "string",
        "null"
      ]
    },
    "emitted_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    }
  }
}
