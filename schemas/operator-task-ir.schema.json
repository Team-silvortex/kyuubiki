{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "kyuubiki.operator-task-ir.schema.json",
  "title": "Kyuubiki operator task IR",
  "type": "object",
  "additionalProperties": true,
  "x-kyuubiki-mirror_constraints": [
    {
      "source": "/operator/kind",
      "mirror": "/execution_program/program_kind",
      "reason": "execution program kind must dispatch the declared operator kind"
    },
    {
      "source": "/operator/kind",
      "mirror": "/execution_program/entrypoint/operator_kind",
      "reason": "entrypoint metadata must not retarget the operator kind"
    },
    {
      "source": "/operator/kind",
      "mirror": "/runtime_hints/operator_kind",
      "reason": "runtime routing hints must preserve the operator kind"
    },
    {
      "source": "/operator/execution/package_ref",
      "mirror": "/execution_program/package_ref",
      "reason": "descriptor package identity and executable package identity must match"
    },
    {
      "source": "/execution_program/package_ref",
      "mirror": "/runtime_hints/package_ref",
      "reason": "runtime fetch hints must point at the same executable package"
    },
    {
      "source": "/execution_program/package_version",
      "mirror": "/runtime_hints/package_version",
      "reason": "runtime fetch hints must target the same package version"
    }
  ],
  "$defs": {
    "sha256Hex": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "stringArray": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "required": [
    "schema_version",
    "task_id",
    "operator",
    "descriptor_authoring",
    "input_artifact",
    "config",
    "execution_program",
    "runtime_hints",
    "integrity"
  ],
  "properties": {
    "schema_version": { "const": "kyuubiki.operator-task-ir/v1" },
    "task_id": { "type": "string", "minLength": 1 },
    "operator": {
      "type": "object",
      "required": ["id", "family", "kind", "execution"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "version": { "type": "string" },
        "domain": { "type": "string" },
        "family": { "type": "string", "minLength": 1 },
        "kind": {
          "type": "string",
          "enum": ["solver", "transform", "extract", "export", "workflow_bridge"]
        },
        "operator_category_id": { "type": ["string", "null"] },
        "capability_tags": {
          "type": "array",
          "items": { "type": "string" }
        },
        "execution": {
          "type": "object",
          "required": ["package_ref"],
          "properties": {
            "package_ref": {
              "type": "string",
              "pattern": "^orchestra://operator-package/.+"
            },
            "package_version": { "type": "string" },
            "integrity": { "type": ["object", "null"] },
            "required_capabilities": { "$ref": "#/$defs/stringArray" },
            "placement_tags": { "$ref": "#/$defs/stringArray" },
            "agent_fetchable": { "type": "boolean" }
          }
        }
      }
    },
    "descriptor_authoring": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "mode",
        "runtime",
        "source",
        "hot_reloadable",
        "execution_language"
      ],
      "properties": {
        "schema_version": { "const": "kyuubiki.operator-descriptor-authoring/v1" },
        "mode": {
          "type": "string",
          "enum": ["elixir_control_plane", "rust_native", "external_sdk"]
        },
        "runtime": { "type": "string", "minLength": 1 },
        "source": { "type": "string", "minLength": 1 },
        "hot_reloadable": { "type": "boolean" },
        "execution_language": { "const": "language_neutral" }
      }
    },
    "node": { "type": "object" },
    "input_artifact": { "type": "object" },
    "config": { "type": "object" },
    "execution_program": {
      "$ref": "operator-execution-program.schema.json"
    },
    "dataset_contract": { "type": "object" },
    "orchestration_context": { "type": "object" },
    "runtime_hints": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "authority_mode",
        "execution_mode",
        "package_ref",
        "package_version",
        "placement_tags",
        "required_capabilities",
        "cache_scope",
        "agent_fetchable",
        "operator_kind"
      ],
      "properties": {
        "authority_mode": {
          "type": "string",
          "enum": ["central_operator_library", "single_orchestrator", "offline_mesh", "self_directed"]
        },
        "execution_mode": {
          "type": "string",
          "enum": ["orchestra_fetch", "agent_local", "offline_mesh_fetch"]
        },
        "source_ref": { "type": ["string", "null"] },
        "package_ref": {
          "type": ["string", "null"],
          "pattern": "^orchestra://operator-package/.+"
        },
        "package_version": { "type": "string", "minLength": 1 },
        "placement_tags": { "$ref": "#/$defs/stringArray" },
        "required_capabilities": { "$ref": "#/$defs/stringArray" },
        "cache_scope": {
          "type": "string",
          "enum": ["job", "session", "agent", "none"]
        },
        "agent_fetchable": { "type": "boolean" },
        "operator_kind": {
          "type": "string",
          "enum": ["solver", "transform", "extract", "export", "workflow_bridge"]
        }
      }
    },
    "integrity": {
      "type": "object",
      "required": ["descriptor_digest", "task_digest", "task_digest_fields", "digest_algorithm"],
      "properties": {
        "operator_integrity": { "type": ["object", "null"] },
        "descriptor_digest": { "$ref": "#/$defs/sha256Hex" },
        "task_digest": { "$ref": "#/$defs/sha256Hex" },
        "task_digest_fields": {
          "type": "array",
          "items": { "type": "string" },
          "contains": { "const": "execution_program" }
        },
        "digest_algorithm": { "const": "sha256" }
      }
    }
  }
}
