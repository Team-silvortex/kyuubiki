{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kyuubiki.dev/schemas/material-research-bundle.schema.json",
  "title": "Kyuubiki Material Research Bundle",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "bundle_id",
    "generated_at_utc",
    "posture",
    "study",
    "artifact_checksums",
    "reproducibility",
    "execution_trace",
    "research_evidence",
    "validation_evidence",
    "summary",
    "initial_exploration",
    "next_round_execution_plan",
    "next_exploration",
    "chain"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "schema_version": {
      "const": "kyuubiki.material-research-bundle/v1"
    },
    "bundle_id": {
      "type": "string",
      "minLength": 1
    },
    "generated_at_utc": {
      "type": "string",
      "minLength": 1
    },
    "posture": {
      "const": "screening_research_bundle"
    },
    "study": {
      "type": "string",
      "minLength": 1
    },
    "artifact_checksums": {
      "$ref": "#/$defs/artifactChecksums"
    },
    "reproducibility": {
      "$ref": "#/$defs/reproducibility"
    },
    "execution_trace": {
      "$ref": "#/$defs/executionTrace"
    },
    "research_evidence": {
      "$ref": "#/$defs/researchEvidence"
    },
    "validation_evidence": {
      "$ref": "#/$defs/validationEvidence"
    },
    "summary": {
      "$ref": "#/$defs/summary"
    },
    "initial_exploration": {
      "type": "object",
      "additionalProperties": true,
      "required": ["schema_version"],
      "properties": {
        "schema_version": {
          "const": "kyuubiki.material-exploration-run/v1"
        }
      }
    },
    "next_round_execution_plan": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "schema_version",
        "decision",
        "iteration",
        "runnable_step_count"
      ],
      "properties": {
        "schema_version": {
          "const": "kyuubiki.material-exploration-next-round-execution/v1"
        },
        "decision": {
          "type": "string",
          "minLength": 1
        },
        "iteration": {
          "type": "integer",
          "minimum": 1
        },
        "runnable_step_count": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "next_exploration": {
      "type": "object",
      "additionalProperties": true,
      "required": ["schema_version"],
      "properties": {
        "schema_version": {
          "const": "kyuubiki.material-exploration-run/v1"
        }
      }
    },
    "chain": {
      "type": "object",
      "additionalProperties": true,
      "required": ["schema_version"],
      "properties": {
        "schema_version": {
          "const": "kyuubiki.material-exploration-chain/v1"
        }
      }
    }
  },
  "$defs": {
    "artifactChecksums": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "initial_exploration_sha256",
        "next_round_execution_plan_sha256",
        "next_exploration_sha256",
        "chain_sha256"
      ],
      "properties": {
        "initial_exploration_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "next_round_execution_plan_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "next_exploration_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "chain_sha256": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "reproducibility": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "workspace",
        "initial_command",
        "plan_next_command_template",
        "run_next_command_template",
        "chain_next_command_template"
      ],
      "properties": {
        "workspace": {
          "type": "string",
          "minLength": 1
        },
        "initial_command": {
          "$ref": "#/$defs/argv"
        },
        "plan_next_command_template": {
          "$ref": "#/$defs/argv"
        },
        "run_next_command_template": {
          "$ref": "#/$defs/argv"
        },
        "chain_next_command_template": {
          "$ref": "#/$defs/argv"
        },
        "transient_work_files": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "executionTrace": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "initial_duration_ms",
        "plan_next_duration_ms",
        "run_next_duration_ms",
        "chain_next_duration_ms"
      ],
      "properties": {
        "initial_duration_ms": {
          "type": "integer",
          "minimum": 0
        },
        "plan_next_duration_ms": {
          "type": "integer",
          "minimum": 0
        },
        "run_next_duration_ms": {
          "type": "integer",
          "minimum": 0
        },
        "chain_next_duration_ms": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "winner_candidate_id",
        "reliability_decision",
        "material_card_ref_count",
        "material_card_refs",
        "next_round_decision",
        "chain_stop_reason"
      ],
      "properties": {
        "winner_candidate_id": {
          "type": "string",
          "minLength": 1
        },
        "reliability_decision": {
          "type": "string",
          "minLength": 1
        },
        "material_card_ref_count": {
          "type": "integer",
          "minimum": 1
        },
        "material_card_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/materialCardRef"
          }
        },
        "next_round_decision": {
          "type": "string",
          "minLength": 1
        },
        "runnable_next_step_count": {
          "type": "integer",
          "minimum": 0
        },
        "next_iteration": {
          "type": "integer",
          "minimum": 1
        },
        "chain_stop_reason": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "researchEvidence": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "schema_version",
        "candidate_count",
        "ranked_candidate_ids",
        "winner_candidate_id",
        "primary_metric_ids",
        "metric_objective_count",
        "violated_quality_gate_ids",
        "focus_candidate_ids",
        "quality_gate_decision",
        "plan_decision",
        "plan_step_count",
        "chain_round_count",
        "chain_trace_round_count",
        "final_winner_candidate_id"
      ],
      "properties": {
        "schema_version": {
          "const": "kyuubiki.material-research-evidence/v1"
        },
        "candidate_count": {
          "type": "integer",
          "minimum": 1
        },
        "ranked_candidate_ids": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "winner_candidate_id": {
          "type": "string",
          "minLength": 1
        },
        "optimization_profile_id": {
          "type": "string",
          "minLength": 1
        },
        "primary_metric_ids": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "metric_objective_count": {
          "type": "integer",
          "minimum": 1
        },
        "violated_quality_gate_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "focus_candidate_ids": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "quality_gate_decision": {
          "type": "string",
          "minLength": 1
        },
        "plan_decision": {
          "type": "string",
          "minLength": 1
        },
        "plan_step_count": {
          "type": "integer",
          "minimum": 0
        },
        "chain_round_count": {
          "type": "integer",
          "minimum": 1
        },
        "chain_trace_round_count": {
          "type": "integer",
          "minimum": 1
        },
        "final_winner_candidate_id": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "validationEvidence": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "schema_version",
        "validation_posture",
        "baseline_refs",
        "candidate_confidence_counts",
        "sensitivity_summary",
        "acceptance_criteria",
        "uncertainty_summary",
        "validation_readiness",
        "external_validation_plan",
        "violated_quality_gate_ids"
      ],
      "properties": {
        "schema_version": {
          "const": "kyuubiki.material-validation-evidence/v1"
        },
        "validation_posture": {
          "const": "screening_validation"
        },
        "baseline_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/validationBaselineRef"
          }
        },
        "candidate_confidence_counts": {
          "$ref": "#/$defs/confidenceCounts"
        },
        "sensitivity_summary": {
          "$ref": "#/$defs/sensitivitySummary"
        },
        "acceptance_criteria": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/acceptanceCriterion"
          }
        },
        "uncertainty_summary": {
          "$ref": "#/$defs/uncertaintySummary"
        },
        "validation_readiness": {
          "$ref": "#/$defs/validationReadiness"
        },
        "external_validation_plan": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "violated_quality_gate_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "validationReadiness": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "schema_version",
        "decision",
        "score",
        "blocking_reasons",
        "next_validation_actions"
      ],
      "properties": {
        "schema_version": {
          "const": "kyuubiki.material-validation-readiness/v1"
        },
        "decision": {
          "const": "screening_only"
        },
        "score": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "blocking_reasons": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          },
          "contains": {
            "const": "external_validation_required"
          }
        },
        "next_validation_actions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "validationBaselineRef": {
      "type": "object",
      "additionalProperties": true,
      "required": ["baseline_id", "kind", "status", "scope"],
      "properties": {
        "baseline_id": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "minLength": 1
        },
        "scope": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "confidenceCounts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["low", "medium", "high", "unknown"],
      "properties": {
        "low": {
          "type": "integer",
          "minimum": 0
        },
        "medium": {
          "type": "integer",
          "minimum": 0
        },
        "high": {
          "type": "integer",
          "minimum": 0
        },
        "unknown": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "sensitivitySummary": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "schema_version",
        "method",
        "primary_metric_ids",
        "focus_candidate_ids",
        "winner_stability_state",
        "chain_trace_round_count"
      ],
      "properties": {
        "schema_version": {
          "const": "kyuubiki.material-sensitivity-summary/v1"
        },
        "method": {
          "type": "string",
          "minLength": 1
        },
        "primary_metric_ids": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "focus_candidate_ids": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "winner_stability_state": {
          "type": "string",
          "minLength": 1
        },
        "chain_trace_round_count": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "acceptanceCriterion": {
      "type": "object",
      "additionalProperties": true,
      "required": ["criterion_id", "metric_id", "operator", "status"],
      "properties": {
        "criterion_id": {
          "type": "string",
          "minLength": 1
        },
        "metric_id": {
          "type": "string",
          "minLength": 1
        },
        "operator": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "uncertaintySummary": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "schema_version",
        "candidate_confidence_counts",
        "known_limitations",
        "external_validation_required"
      ],
      "properties": {
        "schema_version": {
          "const": "kyuubiki.material-uncertainty-summary/v1"
        },
        "candidate_confidence_counts": {
          "$ref": "#/$defs/confidenceCounts"
        },
        "known_limitations": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "external_validation_required": {
          "type": "boolean"
        }
      }
    },
    "argv": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "materialCardRef": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "material_card_id",
        "schema_version",
        "candidate_id",
        "confidence",
        "unit_system",
        "parameter_scope"
      ],
      "properties": {
        "material_card_id": {
          "type": "string",
          "minLength": 1
        },
        "schema_version": {
          "const": "kyuubiki.material-card/v1"
        },
        "candidate_id": {
          "type": "string",
          "minLength": 1
        },
        "confidence": {
          "type": "string",
          "minLength": 1
        },
        "unit_system": {
          "type": "string",
          "minLength": 1
        },
        "parameter_scope": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    }
  }
}
