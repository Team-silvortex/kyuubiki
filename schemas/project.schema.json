{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kyuubiki.local/schemas/project.schema.json",
  "title": "Kyuubiki Project Bundle",
  "description": "Portable JSON project package for persisted project, workspace, automation, model, and version data.",
  "type": "object",
  "required": ["project_schema_version", "project", "models", "model_versions"],
  "properties": {
    "project_schema_version": {
      "type": "string",
      "const": "kyuubiki.project/v2"
    },
    "exported_at": {
      "type": "string",
      "format": "date-time"
    },
    "project_file_manifest": {
      "$ref": "#/$defs/projectFileManifestV1"
    },
    "project": {
      "$ref": "#/$defs/projectRecordV1"
    },
    "models": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/modelRecordV1"
      }
    },
    "model_versions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/modelVersionRecordV1"
      }
    },
    "jobs": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "results": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/jobResultRecordV1"
      }
    },
    "active_model_id": {
      "type": ["string", "null"]
    },
    "active_version_id": {
      "type": ["string", "null"]
    },
    "workspace_snapshot": {
      "type": ["object", "null"],
      "oneOf": [
        { "$ref": "model.schema.json#/$defs/axialBarModelV1" },
        { "$ref": "model.schema.json#/$defs/truss2dModelV1" },
        { "$ref": "model.schema.json#/$defs/truss3dModelV1" },
        { "$ref": "model.schema.json#/$defs/planeTriangle2dModelV1" },
        { "type": "null" }
      ]
    },
    "automation_presets": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/automationPresetRecordV1"
      }
    },
    "asset_catalog": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/projectAssetMetaRecordV1"
      }
    },
    "asset_references": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/projectAssetReferenceRecordV1"
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "projectFileManifestV1": {
      "type": "object",
      "required": [
        "layout_version",
        "engine_manifest_path",
        "root_manifest_path",
        "project_record_path",
        "workspace_settings_path",
        "workspace_snapshot_path",
        "automation_presets_path",
        "asset_catalog_path",
        "asset_references_path",
        "model_directory",
        "version_directory",
        "job_directory",
        "result_directory"
      ],
      "properties": {
        "layout_version": { "type": "string", "const": "kyuubiki.project-layout/v1" },
        "engine_manifest_path": { "type": "string", "minLength": 1 },
        "root_manifest_path": { "type": "string", "minLength": 1 },
        "project_record_path": { "type": "string", "minLength": 1 },
        "workspace_settings_path": { "type": "string", "minLength": 1 },
        "workspace_snapshot_path": { "type": "string", "minLength": 1 },
        "automation_presets_path": { "type": "string", "minLength": 1 },
        "asset_catalog_path": { "type": "string", "minLength": 1 },
        "asset_references_path": { "type": "string", "minLength": 1 },
        "model_directory": { "type": "string", "minLength": 1 },
        "version_directory": { "type": "string", "minLength": 1 },
        "job_directory": { "type": "string", "minLength": 1 },
        "result_directory": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "projectRecordV1": {
      "type": "object",
      "required": ["project_id", "name", "inserted_at", "updated_at"],
      "properties": {
        "project_id": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "description": { "type": ["string", "null"] },
        "inserted_at": { "type": "string", "format": "date-time" },
        "updated_at": { "type": "string", "format": "date-time" }
      },
      "additionalProperties": false
    },
    "automationPresetRecordV1": {
      "type": "object",
      "required": ["presetId", "projectId", "name", "macro", "updatedAt"],
      "properties": {
        "presetId": { "type": "string", "minLength": 1 },
        "projectId": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "updatedAt": { "type": "string", "format": "date-time" },
        "macro": {
          "type": "object",
          "required": ["id", "steps"],
          "properties": {
            "id": { "type": "string", "minLength": 1 },
            "steps": {
              "type": "array",
              "minItems": 1,
              "items": {
                "$ref": "#/$defs/automationMacroStepV1"
              }
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "automationMacroStepV1": {
      "type": "object",
      "required": ["action"],
      "properties": {
        "action": { "type": "string", "minLength": 1 },
        "payload": { "type": "object" }
      },
      "additionalProperties": false
    },
    "projectAssetMetaRecordV1": {
      "type": "object",
      "required": ["guid", "meta_version", "kind", "path", "source_id"],
      "properties": {
        "guid": { "type": "string", "minLength": 1 },
        "meta_version": { "type": "string", "const": "kyuubiki.asset-meta/v1" },
        "kind": {
          "type": "string",
          "enum": [
            "project",
            "workspace_settings",
            "workspace_snapshot",
            "automation_preset",
            "model",
            "model_version",
            "job",
            "result"
          ]
        },
        "path": { "type": "string", "minLength": 1 },
        "source_id": { "type": "string", "minLength": 1 },
        "name": { "type": "string" },
        "updated_at": { "type": ["string", "null"], "format": "date-time" }
      },
      "additionalProperties": false
    },
    "projectAssetReferenceRecordV1": {
      "type": "object",
      "required": ["from_guid", "relation", "to_guid"],
      "properties": {
        "from_guid": { "type": "string", "minLength": 1 },
        "relation": {
          "type": "string",
          "enum": [
            "contains",
            "active_model",
            "active_version",
            "workspace_snapshot_of",
            "workspace_settings_for",
            "automation_for",
            "version_of",
            "job_for_project",
            "job_for_version",
            "result_for_job"
          ]
        },
        "to_guid": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "modelRecordV1": {
      "type": "object",
      "required": [
        "model_id",
        "project_id",
        "name",
        "kind",
        "model_schema_version",
        "payload",
        "inserted_at",
        "updated_at"
      ],
      "properties": {
        "model_id": { "type": "string", "minLength": 1 },
        "project_id": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "kind": { "type": "string", "minLength": 1 },
        "material": { "type": ["string", "null"] },
        "model_schema_version": { "type": "string", "const": "kyuubiki.model/v1" },
        "payload": {
          "oneOf": [
            { "$ref": "model.schema.json#/$defs/axialBarModelV1" },
            { "$ref": "model.schema.json#/$defs/truss2dModelV1" },
            { "$ref": "model.schema.json#/$defs/truss3dModelV1" },
            { "$ref": "model.schema.json#/$defs/planeTriangle2dModelV1" }
          ]
        },
        "latest_version_id": { "type": ["string", "null"] },
        "latest_version_number": { "type": ["integer", "null"] },
        "inserted_at": { "type": "string", "format": "date-time" },
        "updated_at": { "type": "string", "format": "date-time" }
      },
      "additionalProperties": false
    },
    "modelVersionRecordV1": {
      "type": "object",
      "required": [
        "version_id",
        "project_id",
        "model_id",
        "version_number",
        "kind",
        "model_schema_version",
        "payload",
        "inserted_at",
        "updated_at"
      ],
      "properties": {
        "version_id": { "type": "string", "minLength": 1 },
        "project_id": { "type": "string", "minLength": 1 },
        "model_id": { "type": "string", "minLength": 1 },
        "name": { "type": ["string", "null"] },
        "version_number": { "type": "integer", "minimum": 1 },
        "kind": { "type": "string", "minLength": 1 },
        "material": { "type": ["string", "null"] },
        "model_schema_version": { "type": "string", "const": "kyuubiki.model/v1" },
        "payload": {
          "oneOf": [
            { "$ref": "model.schema.json#/$defs/axialBarModelV1" },
            { "$ref": "model.schema.json#/$defs/truss2dModelV1" },
            { "$ref": "model.schema.json#/$defs/truss3dModelV1" },
            { "$ref": "model.schema.json#/$defs/planeTriangle2dModelV1" }
          ]
        },
        "inserted_at": { "type": "string", "format": "date-time" },
        "updated_at": { "type": "string", "format": "date-time" }
      },
      "additionalProperties": false
    },
    "jobResultRecordV1": {
      "type": "object",
      "required": ["job_id", "result"],
      "properties": {
        "job_id": { "type": "string", "minLength": 1 },
        "status": { "type": "string" },
        "worker_id": { "type": ["string", "null"] },
        "result": { "type": "object" }
      },
      "additionalProperties": true
    }
  }
}
