{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "kyuubiki.material-envelope-catalog-request.schema.json",
  "title": "Kyuubiki material envelope catalog request",
  "type": "object",
  "additionalProperties": false,
  "required": ["workflow_id", "input_artifacts"],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "workflow_id": {
      "const": "workflow.material-study-envelope-ranking-json"
    },
    "input_artifacts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["material_rows"],
      "properties": {
        "material_rows": {
          "type": "object",
          "additionalProperties": false,
          "required": ["rows"],
          "properties": {
            "rows": {
              "type": "array",
              "minItems": 1,
              "maxItems": 128,
              "items": {
                "$ref": "#/$defs/materialCandidateRow"
              }
            }
          }
        }
      }
    }
  },
  "$defs": {
    "materialCandidateRow": {
      "type": "object",
      "additionalProperties": true,
      "required": ["case_id", "summaries"],
      "properties": {
        "case_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "summaries": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "type": "object"
          }
        }
      }
    }
  }
}
