{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kyuubiki.dev/schemas/language-pack.schema.json",
  "title": "Kyuubiki language pack",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "id",
    "language",
    "name",
    "version",
    "source",
    "updatedAt",
    "overrides"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "kyuubiki.language-pack/v1"
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "language": {
      "type": "string",
      "minLength": 2,
      "description": "BCP-47 style language code such as en, zh, ja, fr."
    },
    "targetSurface": {
      "type": "string",
      "enum": ["workbench", "hub"],
      "description": "Optional UI surface target. Omit only for legacy local packs."
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "versionLine": {
      "type": "string",
      "description": "Optional product line target such as moxi 2.x."
    },
    "targetAppVersion": {
      "type": "string",
      "description": "Optional shipped desktop/workbench version target such as 1.13.0."
    },
    "source": {
      "type": "string",
      "enum": ["imported", "downloaded"]
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "description": {
      "type": "string"
    },
    "overrides": {
      "type": "object",
      "description": "Deep partial override tree for the built-in workbench copy dictionary.",
      "additionalProperties": {
        "$ref": "#/$defs/translationValue"
      }
    }
  },
  "$defs": {
    "translationValue": {
      "description": "Leaf string, array replacement, or nested object override.",
      "anyOf": [
        { "type": "string" },
        {
          "type": "number"
        },
        {
          "type": "boolean"
        },
        {
          "type": "array",
          "items": {
            "$ref": "#/$defs/translationValue"
          }
        },
        {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/translationValue"
          }
        }
      ]
    }
  }
}
