{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kyuubiki.dev/schemas/agent-manifest.schema.json",
  "title": "Kyuubiki Agent Manifest",
  "type": "object",
  "required": ["schema_version", "deployment_mode", "agents"],
  "properties": {
    "schema_version": {
      "const": "kyuubiki.agent-manifest/v1"
    },
    "deployment_mode": {
      "type": "string",
      "enum": ["local", "cloud", "distributed"]
    },
    "control_plane": {
      "type": "object",
      "properties": {
        "orchestrator_url": { "type": "string" },
        "frontend_url": { "type": "string" }
      },
      "additionalProperties": false
    },
    "agents": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "host", "port"],
        "properties": {
          "id": { "type": "string" },
          "host": { "type": "string" },
          "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
          "role": { "type": "string" },
          "region": { "type": "string" },
          "zone": { "type": "string" },
          "capacity": { "type": "integer", "minimum": 1 },
          "tags": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
