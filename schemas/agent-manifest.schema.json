{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kyuubiki.dev/schemas/agent-manifest.schema.json",
  "title": "Kyuubiki Agent Manifest",
  "type": "object",
  "required": ["schema_version", "deployment_mode", "agents"],
  "properties": {
    "schema_version": {
      "const": "kyuubiki.agent-manifest/v1"
    },
    "deployment_mode": {
      "type": "string",
      "enum": ["local", "cloud", "distributed"]
    },
    "control_plane": {
      "type": "object",
      "properties": {
        "orchestrator_url": { "type": "string" },
        "frontend_url": { "type": "string" }
      },
      "additionalProperties": false
    },
    "agents": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "host", "port"],
        "properties": {
          "id": { "type": "string" },
          "host": { "type": "string" },
          "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
          "role": { "type": "string" },
          "region": { "type": "string" },
          "zone": { "type": "string" },
          "capacity": { "type": "integer", "minimum": 1 },
          "control_mode": {
            "type": "string",
            "enum": ["orch_managed", "offline_mesh", "standalone"]
          },
          "orch_id": { "type": "string" },
          "orch_session_id": { "type": "string" },
          "engine": {
            "type": "object",
            "properties": {
              "lifecycle": {
                "type": "string",
                "enum": ["agent_embedded"]
              },
              "task_source": {
                "type": "string",
                "enum": [
                  "bound_orchestra_dispatch",
                  "manual_or_mesh_dispatch",
                  "manual_or_sdk"
                ]
              },
              "operator_source": {
                "type": "string",
                "enum": ["bound_orchestra_fetch"]
              },
              "operator_cache_policy": {
                "type": "string",
                "enum": ["temporary_execution_cache"]
              }
            },
            "additionalProperties": false
          },
          "tags": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
