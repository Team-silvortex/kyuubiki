{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kyuubiki.dev/schemas/material-study-execution-plan.schema.json",
  "title": "Kyuubiki Material Study Execution Plan",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "study_id",
    "step_count",
    "solve_step_count",
    "candidate_count",
    "candidate_ids",
    "actions",
    "steps",
    "recommended_command",
    "dispatch_notes"
  ],
  "properties": {
    "schema_version": {
      "const": "kyuubiki.material-study-execution-plan/v1"
    },
    "study_id": {
      "type": "string",
      "minLength": 1
    },
    "step_count": {
      "type": "integer",
      "minimum": 1
    },
    "solve_step_count": {
      "type": "integer",
      "minimum": 1
    },
    "candidate_count": {
      "type": "integer",
      "minimum": 1
    },
    "candidate_ids": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "actions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/workflowStep"
      }
    },
    "recommended_command": {
      "type": "string",
      "minLength": 1
    },
    "dispatch_notes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "$defs": {
    "workflowStep": {
      "type": "object",
      "additionalProperties": true,
      "required": ["action", "payload"],
      "properties": {
        "action": {
          "type": "string",
          "minLength": 1
        },
        "payload": {
          "type": "object"
        }
      }
    }
  }
}
