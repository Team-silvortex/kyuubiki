{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "kyuubiki.operator-task-batch-preparation.schema.json",
  "title": "Kyuubiki operator task batch preparation result",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "operator_task_batch_preparation_contract",
    "quality_execution_batch_contract",
    "run_id",
    "run_phase",
    "batch_digest",
    "digest_algorithm",
    "started_at",
    "finished_at",
    "task_count",
    "verified_count",
    "error_count",
    "summaries"
  ],
  "properties": {
    "operator_task_batch_preparation_contract": {
      "const": "kyuubiki.operator_task_batch_preparation/v1"
    },
    "quality_execution_batch_contract": {
      "const": "kyuubiki.quality_execution_batch/v1"
    },
    "status": {
      "type": "string",
      "enum": ["verified"]
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "run_phase": {
      "const": "prepare"
    },
    "batch_digest": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "digest_algorithm": {
      "const": "sha256"
    },
    "started_at": {
      "type": "string",
      "minLength": 1
    },
    "finished_at": {
      "type": "string",
      "minLength": 1
    },
    "task_count": {
      "type": "integer",
      "minimum": 0
    },
    "verified_count": {
      "type": "integer",
      "minimum": 0
    },
    "error_count": {
      "type": "integer",
      "minimum": 0
    },
    "summaries": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["case_id", "task_id", "task_digest", "operator_id", "status"],
        "properties": {
          "case_id": {
            "type": "string",
            "minLength": 1
          },
          "task_id": {
            "type": "string",
            "minLength": 1
          },
          "task_digest": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          },
          "operator_id": {
            "type": "string",
            "minLength": 1
          },
          "operator_kind": {
            "type": "string",
            "minLength": 1
          },
          "program_id": {
            "type": "string",
            "minLength": 1
          },
          "program_kind": {
            "type": "string",
            "minLength": 1
          },
          "runtime_protocol": {
            "type": "string",
            "minLength": 1
          },
          "abi_kind": {
            "type": "string",
            "minLength": 1
          },
          "entrypoint_kind": {
            "type": "string",
            "minLength": 1
          },
          "entrypoint_name": {
            "type": "string",
            "minLength": 1
          },
          "package_ref": {
            "type": "string"
          },
          "package_version": {
            "type": "string"
          },
          "authority_mode": {
            "type": "string"
          },
          "execution_mode": {
            "type": "string"
          },
          "cache_scope": {
            "type": "string"
          },
          "agent_fetchable": {
            "type": "boolean"
          },
          "status": {
            "type": "string",
            "enum": ["verified", "error"]
          },
          "error": {
            "type": "string"
          }
        }
      }
    }
  }
}
