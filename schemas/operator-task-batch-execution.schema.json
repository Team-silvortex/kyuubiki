{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "kyuubiki.operator-task-batch-execution.schema.json",
  "title": "Kyuubiki operator task batch execution result",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "operator_task_batch_execution_contract",
    "run_id",
    "run_phase",
    "batch_digest",
    "digest_algorithm",
    "started_at",
    "finished_at",
    "task_count",
    "executed_count",
    "ok_count",
    "error_count",
    "error_codes",
    "error_code_counts",
    "failed_case_ids",
    "results"
  ],
  "properties": {
    "operator_task_batch_execution_contract": {
      "const": "kyuubiki.operator_task_batch_execution/v1"
    },
    "status": {
      "type": "string",
      "enum": ["executed"]
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "run_phase": {
      "const": "execute"
    },
    "batch_digest": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "digest_algorithm": {
      "const": "sha256"
    },
    "started_at": {
      "type": "string",
      "minLength": 1
    },
    "finished_at": {
      "type": "string",
      "minLength": 1
    },
    "task_count": {
      "type": "integer",
      "minimum": 0
    },
    "executed_count": {
      "type": "integer",
      "minimum": 0
    },
    "ok_count": {
      "type": "integer",
      "minimum": 0
    },
    "error_count": {
      "type": "integer",
      "minimum": 0
    },
    "error_codes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "error_code_counts": {
      "type": "object",
      "additionalProperties": {
        "type": "integer",
        "minimum": 1
      }
    },
    "failed_case_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "results": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["case_id", "task_id", "task_digest", "operator_id", "status"],
        "properties": {
          "case_id": {
            "type": "string",
            "minLength": 1
          },
          "task_id": {
            "type": "string",
            "minLength": 1
          },
          "task_digest": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          },
          "operator_id": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": ["ok", "error"]
          },
          "result": {
            "type": "object"
          },
          "error": {
            "type": "string"
          },
          "error_code": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
