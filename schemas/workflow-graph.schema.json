{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kyuubiki.dev/schemas/workflow-graph.schema.json",
  "title": "Kyuubiki workflow graph",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "id",
    "name",
    "version",
    "entry_nodes",
    "nodes",
    "edges"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "kyuubiki.workflow-graph/v1"
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "dataset_contract": {
      "$ref": "workflow-dataset.schema.json"
    },
    "entry_nodes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "output_nodes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "defaults": {
      "$ref": "#/$defs/workflowDefaults"
    },
    "dispatch_policy": {
      "$ref": "#/$defs/workflowDispatchPolicy"
    },
    "operator_fetch_plan": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/operatorFetchEntry"
      }
    },
    "placement_tags": {
      "$ref": "#/$defs/stringTagList"
    },
    "required_capabilities": {
      "$ref": "#/$defs/stringTagList"
    },
    "nodes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/workflowNode"
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/workflowEdge"
      }
    }
  },
  "$defs": {
    "workflowDefaults": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "cache_policy": {
          "type": "string",
          "enum": ["ephemeral", "cached", "persisted"]
        },
        "orchestrated": {
          "type": "boolean"
        },
        "dispatch_policy": {
          "$ref": "#/$defs/workflowDispatchPolicy"
        },
        "placement_tags": {
          "$ref": "#/$defs/stringTagList"
        },
        "required_capabilities": {
          "$ref": "#/$defs/stringTagList"
        }
      }
    },
    "workflowNode": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "kind",
        "inputs",
        "outputs"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "type": "string",
          "enum": [
            "input",
            "solve",
            "transform",
            "extract",
            "export",
            "condition",
            "output"
          ]
        },
        "operator_id": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string"
        },
        "config": {
          "type": "object"
        },
        "cache_policy": {
          "type": "string",
          "enum": ["ephemeral", "cached", "persisted"]
        },
        "placement_tags": {
          "$ref": "#/$defs/stringTagList"
        },
        "required_capabilities": {
          "$ref": "#/$defs/stringTagList"
        },
        "inputs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/workflowPort"
          }
        },
        "outputs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/workflowPort"
          }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "kind": {
                "enum": ["solve", "transform", "extract", "export", "condition"]
              }
            }
          },
          "then": {
            "required": ["operator_id"]
          }
        }
      ]
    },
    "workflowPort": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "artifact_type"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "artifact_type": {
          "type": "string",
          "minLength": 1
        },
        "required": {
          "type": "boolean",
          "default": true
        },
        "cardinality": {
          "type": "string",
          "enum": ["one", "many"]
        },
        "dataset_value": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "workflowEdge": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "from",
        "to",
        "artifact_type"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "from": {
          "$ref": "#/$defs/nodePortRef"
        },
        "to": {
          "$ref": "#/$defs/nodePortRef"
        },
        "artifact_type": {
          "type": "string",
          "minLength": 1
        },
        "dataset_value": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "nodePortRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "node",
        "port"
      ],
      "properties": {
        "node": {
          "type": "string",
          "minLength": 1
        },
        "port": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "workflowDispatchPolicy": {
      "type": "string",
      "enum": [
        "orchestra_only",
        "central_fetch",
        "direct_mesh",
        "local_only"
      ]
    },
    "stringTagList": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "operatorFetchEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "node_id",
        "operator_id"
      ],
      "properties": {
        "node_id": {
          "type": "string",
          "minLength": 1
        },
        "operator_id": {
          "type": "string",
          "minLength": 1
        },
        "package_ref": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "integrity": {
          "type": "string",
          "minLength": 1
        },
        "cache_scope": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
