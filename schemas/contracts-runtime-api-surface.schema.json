{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kyuubiki.dev/schemas/contracts-runtime-api-surface.schema.json",
  "title": "Kyuubiki contracts runtime API surface",
  "type": "object",
  "required": ["schema_version", "module_id", "runtime_api"],
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string" },
    "schema_version": { "const": "kyuubiki.contracts-runtime-api-surface/v1" },
    "module_id": { "const": "contracts" },
    "runtime_api": {
      "type": "object",
      "required": ["owner", "contract_families", "verification_commands"],
      "additionalProperties": false,
      "properties": {
        "owner": { "const": "contracts" },
        "contract_families": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/contractFamily" }
        },
        "verification_commands": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    }
  },
  "$defs": {
    "contractFamily": {
      "type": "object",
      "required": ["id", "sources", "client_surfaces", "stability_contracts"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "sources": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/repoPath" }
        },
        "client_surfaces": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "service_surfaces": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/serviceSurface" }
        },
        "stability_contracts": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "serviceSurface": {
      "type": "object",
      "required": ["id", "module_id", "kind"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "module_id": { "type": "string", "minLength": 1 },
        "kind": { "type": "string", "minLength": 1 }
      }
    },
    "repoPath": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!/)(?![A-Za-z]:)(?!.*(^|/)\\.\\.(/|$)).+"
    }
  }
}
