{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kyuubiki.local/schemas/operator-qualification-readiness.schema.json",
  "title": "Kyuubiki Operator Qualification Readiness Report",
  "type": "object",
  "required": [
    "schema_version",
    "version_line",
    "generated_at_utc",
    "summary",
    "next_actions",
    "candidates"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "const": "kyuubiki.operator-qualification-readiness/v1" },
    "version_line": { "type": "string", "pattern": "^moxi 2\\.0\\.x$" },
    "generated_at_utc": { "type": "string", "minLength": 10 },
    "summary": {
      "type": "object",
      "required": [
        "candidates",
        "collecting",
        "planned",
        "with_entries",
        "not_started",
        "broken",
        "validation_profile_count",
        "release_candidate_profiles",
        "component_profiles",
        "candidates_missing_release_profile",
        "next_action_count",
        "target_levels",
        "operator_trust_levels",
        "evidence_phases",
        "release_gate_impacts",
        "release_review_statuses",
        "release_review_decisions",
        "release_promotion_summaries"
      ],
      "additionalProperties": false,
      "properties": {
        "candidates": { "type": "integer", "minimum": 1 },
        "collecting": { "type": "integer", "minimum": 0 },
        "planned": { "type": "integer", "minimum": 0 },
        "with_entries": { "type": "integer", "minimum": 0 },
        "not_started": { "type": "integer", "minimum": 0 },
        "broken": { "type": "integer", "minimum": 0 },
        "validation_profile_count": { "type": "integer", "minimum": 0 },
        "release_candidate_profiles": { "type": "integer", "minimum": 0 },
        "component_profiles": { "type": "integer", "minimum": 0 },
        "candidates_missing_release_profile": { "type": "integer", "minimum": 0 },
        "next_action_count": { "type": "integer", "minimum": 0 },
        "target_levels": { "$ref": "#/$defs/targetLevelCounts" },
        "operator_trust_levels": { "$ref": "#/$defs/operatorTrustLevelCounts" },
        "evidence_phases": { "$ref": "#/$defs/evidencePhaseCounts" },
        "release_gate_impacts": { "$ref": "#/$defs/releaseGateImpactCounts" },
        "release_review_statuses": { "$ref": "#/$defs/releaseReviewStatusCounts" },
        "release_review_decisions": { "$ref": "#/$defs/releaseReviewDecisionCounts" },
        "release_promotion_summaries": { "$ref": "#/$defs/releasePromotionSummaryCounts" }
      }
    },
    "next_actions": { "type": "array", "items": { "$ref": "#/$defs/nextAction" } },
    "candidates": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/candidate" } }
  },
  "$defs": {
    "targetLevelCounts": {
      "type": "object",
      "required": ["baseline", "review", "qualification"],
      "additionalProperties": false,
      "properties": {
        "baseline": { "type": "integer", "minimum": 0 },
        "review": { "type": "integer", "minimum": 0 },
        "qualification": { "type": "integer", "minimum": 0 }
      }
    },
    "operatorTrustLevelCounts": {
      "type": "object",
      "required": ["smoke", "baseline", "review", "qualification"],
      "additionalProperties": false,
      "properties": {
        "smoke": { "type": "integer", "minimum": 0 },
        "baseline": { "type": "integer", "minimum": 0 },
        "review": { "type": "integer", "minimum": 0 },
        "qualification": { "type": "integer", "minimum": 0 }
      }
    },
    "evidencePhaseCounts": {
      "type": "object",
      "required": ["planned", "collecting", "ready_for_review", "blocked"],
      "additionalProperties": false,
      "properties": {
        "planned": { "type": "integer", "minimum": 0 },
        "collecting": { "type": "integer", "minimum": 0 },
        "ready_for_review": { "type": "integer", "minimum": 0 },
        "blocked": { "type": "integer", "minimum": 0 }
      }
    },
    "releaseGateImpactCounts": {
      "type": "object",
      "required": ["release_blocker", "release_watch", "experimental_only"],
      "additionalProperties": false,
      "properties": {
        "release_blocker": { "type": "integer", "minimum": 0 },
        "release_watch": { "type": "integer", "minimum": 0 },
        "experimental_only": { "type": "integer", "minimum": 0 }
      }
    },
    "releaseReviewStatusCounts": {
      "type": "object",
      "required": ["missing", "pending_signoff", "approved", "blocked_scope", "rejected"],
      "additionalProperties": false,
      "properties": {
        "missing": { "type": "integer", "minimum": 0 },
        "pending_signoff": { "type": "integer", "minimum": 0 },
        "approved": { "type": "integer", "minimum": 0 },
        "blocked_scope": { "type": "integer", "minimum": 0 },
        "rejected": { "type": "integer", "minimum": 0 }
      }
    },
    "releaseReviewDecisionCounts": {
      "type": "object",
      "required": ["required", "declared", "retained", "missing"],
      "additionalProperties": false,
      "properties": {
        "required": { "type": "integer", "minimum": 0 },
        "declared": { "type": "integer", "minimum": 0 },
        "retained": { "type": "integer", "minimum": 0 },
        "missing": { "type": "integer", "minimum": 0 }
      }
    },
    "releasePromotionSummaryCounts": {
      "type": "object",
      "required": ["required", "retained", "declared", "matched", "missing"],
      "additionalProperties": false,
      "properties": {
        "required": { "type": "integer", "minimum": 0 },
        "retained": { "type": "integer", "minimum": 0 },
        "declared": { "type": "integer", "minimum": 0 },
        "matched": { "type": "integer", "minimum": 0 },
        "missing": { "type": "integer", "minimum": 0 }
      }
    },
    "readiness": { "enum": ["planned", "partially_collecting", "collecting_with_entries", "ready_for_review", "broken", "blocked"] },
    "artifactState": { "enum": ["present", "missing", "command_available", "not_started"] },
    "candidate": {
      "type": "object",
      "required": [
        "candidate_id",
        "priority",
        "domain",
        "target_level",
        "evidence_phase",
        "status",
        "readiness",
        "operator_ids",
        "artifact_counts",
        "artifacts",
        "validation_profiles",
        "primary_blocker",
        "evidence_gaps",
        "graduation_gate",
        "preferred_validation_lane",
        "release_gate_impact"
      ],
      "additionalProperties": false,
      "properties": {
        "candidate_id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
        "priority": { "enum": ["p0", "p1", "p2", "p3"] },
        "domain": { "type": "string", "minLength": 1 },
        "target_level": { "enum": ["baseline", "review", "qualification"] },
        "evidence_phase": { "enum": ["planned", "collecting", "ready_for_review", "blocked"] },
        "status": { "enum": ["planned", "collecting", "ready_for_review", "blocked", "missing_kit"] },
        "readiness": { "$ref": "#/$defs/readiness" },
        "operator_ids": { "type": "array", "minItems": 1, "items": { "type": "string", "pattern": "^solve\\.[a-z0-9_]+$" } },
        "artifact_counts": {
          "type": "object",
          "required": ["total", "present", "command_available", "missing", "not_started"],
          "additionalProperties": false,
          "properties": {
            "total": { "type": "integer", "minimum": 0 },
            "present": { "type": "integer", "minimum": 0 },
            "command_available": { "type": "integer", "minimum": 0 },
            "missing": { "type": "integer", "minimum": 0 },
            "not_started": { "type": "integer", "minimum": 0 }
          }
        },
        "artifacts": { "type": "array", "items": { "$ref": "#/$defs/artifact" } },
        "validation_profiles": { "type": "array", "items": { "$ref": "#/$defs/validationProfile" } },
        "primary_blocker": { "type": "string", "minLength": 1 },
        "evidence_gaps": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "graduation_gate": { "type": "string", "minLength": 1 },
        "preferred_validation_lane": { "type": "string", "pattern": "^make [a-zA-Z0-9_.-]+$" },
        "release_gate_impact": { "enum": ["release_blocker", "release_watch", "experimental_only"] }
      }
    },
    "validationProfile": {
      "type": "object",
      "required": ["profile_id", "profile_role", "trust_goal", "operator_count", "command_count"],
      "additionalProperties": false,
      "properties": {
        "profile_id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9_-]*$" },
        "profile_role": { "enum": ["release_candidate", "component_profile"] },
        "trust_goal": { "type": "string", "minLength": 1 },
        "operator_count": { "type": "integer", "minimum": 0 },
        "command_count": { "type": "integer", "minimum": 0 }
      }
    },
    "artifact": {
      "type": "object",
      "required": ["artifact_id", "kind", "state", "gate"],
      "additionalProperties": false,
      "properties": {
        "artifact_id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
        "kind": { "type": "string", "minLength": 1 },
        "state": { "$ref": "#/$defs/artifactState" },
        "path": { "type": "string", "minLength": 1 },
        "command": { "type": "string", "minLength": 1 },
        "check_command": { "type": ["string", "null"], "minLength": 1 },
        "release_record_state": { "enum": ["missing", "staged_for_review", "attached_to_release", "rejected"] },
        "release_record_path": { "type": "string" },
        "release_review_status": { "enum": ["missing", "pending_signoff", "approved", "blocked_scope", "rejected"] },
        "release_review_gate": { "type": "string" },
        "release_review_decision_path": { "type": "string" },
        "gate": { "type": "string", "minLength": 1 }
      }
    },
    "nextAction": {
      "type": "object",
      "required": [
        "candidate_id",
        "priority",
        "target_level",
        "evidence_phase",
        "readiness",
        "action_kind",
        "artifact_id",
        "artifact_state",
        "artifact_kind",
        "command",
        "check_command",
        "path",
        "gate",
        "review_reason",
        "validation_profile_count",
        "release_candidate_profile_count",
        "preferred_validation_lane",
        "release_gate_impact"
      ],
      "additionalProperties": false,
      "properties": {
        "candidate_id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
        "priority": { "enum": ["p0", "p1", "p2", "p3"] },
        "target_level": { "enum": ["baseline", "review", "qualification"] },
        "evidence_phase": { "enum": ["planned", "collecting", "ready_for_review", "blocked"] },
        "readiness": { "$ref": "#/$defs/readiness" },
        "action_kind": { "enum": ["collect_artifact", "restore_or_generate_artifact", "run_command", "review"] },
        "artifact_id": { "type": ["string", "null"] },
        "artifact_state": { "type": ["string", "null"] },
        "artifact_kind": { "type": ["string", "null"] },
        "command": { "type": ["string", "null"] },
        "check_command": { "type": ["string", "null"] },
        "path": { "type": ["string", "null"] },
        "gate": { "type": "string", "minLength": 1 },
        "review_reason": { "type": ["string", "null"] },
        "validation_profile_count": { "type": "integer", "minimum": 0 },
        "release_candidate_profile_count": { "type": "integer", "minimum": 0 },
        "preferred_validation_lane": { "type": "string", "pattern": "^make [a-zA-Z0-9_.-]+$" },
        "release_gate_impact": { "enum": ["release_blocker", "release_watch", "experimental_only"] }
      }
    }
  }
}
