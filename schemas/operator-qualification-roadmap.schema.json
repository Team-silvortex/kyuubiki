{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kyuubiki.local/schemas/operator-qualification-roadmap.schema.json",
  "title": "Kyuubiki Operator Qualification Roadmap",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "version_line",
    "minimum_candidate_level",
    "candidates"
  ],
  "properties": {
    "schema_version": {
      "const": "kyuubiki.operator-qualification-roadmap/v1"
    },
    "version_line": {
      "type": "string",
      "minLength": 1
    },
    "minimum_candidate_level": {
      "enum": [
        "smoke",
        "baseline",
        "review",
        "qualification"
      ]
    },
    "candidates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "candidate_id",
          "priority",
          "domain",
          "target_level",
          "evidence_phase",
          "operator_ids",
          "rationale",
          "primary_blocker",
          "evidence_gaps",
          "required_artifacts",
          "graduation_gate",
          "preferred_validation_lane",
          "release_gate_impact"
        ],
        "properties": {
          "candidate_id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]*$"
          },
          "priority": {
            "enum": [
              "p0",
              "p1",
              "p2",
              "p3"
            ]
          },
          "domain": {
            "type": "string",
            "minLength": 1
          },
          "target_level": {
            "enum": [
              "baseline",
              "review",
              "qualification"
            ]
          },
          "evidence_phase": {
            "enum": [
              "planned",
              "collecting",
              "ready_for_review",
              "blocked"
            ]
          },
          "operator_ids": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "pattern": "^solve\\.[a-z0-9_]+$"
            },
            "uniqueItems": true
          },
          "rationale": {
            "type": "string",
            "minLength": 1
          },
          "primary_blocker": {
            "type": "string",
            "minLength": 1
          },
          "evidence_gaps": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "required_artifacts": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "graduation_gate": {
            "type": "string",
            "minLength": 1
          },
          "preferred_validation_lane": {
            "type": "string",
            "pattern": "^make [a-zA-Z0-9_.-]+$"
          },
          "release_gate_impact": {
            "enum": [
              "release_blocker",
              "release_watch",
              "experimental_only"
            ]
          }
        }
      }
    }
  }
}
