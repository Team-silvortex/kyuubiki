{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kyuubiki.dev/schemas/component-integrity-report.schema.json",
  "title": "Kyuubiki component integrity report",
  "type": "object",
  "required": [
    "schema_version",
    "protocol_schema_version",
    "install_contract_schema_version",
    "shipping_version",
    "status",
    "component_count",
    "required_layout_count",
    "covered_required_layout_count",
    "central_components",
    "issues"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "const": "kyuubiki.component-integrity-report/v1" },
    "protocol_schema_version": { "const": "kyuubiki.component-integrity/v1" },
    "install_contract_schema_version": { "const": "kyuubiki.installation-contract/v1" },
    "shipping_version": { "type": "string", "minLength": 1 },
    "status": { "enum": ["ok", "fail"] },
    "component_count": { "type": "integer", "minimum": 0 },
    "required_layout_count": { "type": "integer", "minimum": 0 },
    "covered_required_layout_count": { "type": "integer", "minimum": 0 },
    "central_components": {
      "type": "array",
      "items": { "$ref": "#/$defs/componentSummary" }
    },
    "issues": { "type": "array", "items": { "type": "string" } }
  },
  "$defs": {
    "componentSummary": {
      "type": "object",
      "required": ["id", "kind", "owner", "version", "owned_paths", "required_paths", "check_commands"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "kind": { "type": "string", "minLength": 1 },
        "owner": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "owned_paths": { "type": "array", "items": { "type": "string" } },
        "required_paths": { "type": "array", "items": { "type": "string" } },
        "check_commands": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
