{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kyuubiki.local/schemas/material-library.schema.json",
  "title": "Kyuubiki Material Library",
  "type": "object",
  "required": ["material_schema_version", "materials"],
  "properties": {
    "material_schema_version": {
      "type": "string",
      "const": "kyuubiki.material/v1"
    },
    "materials": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/material"
      }
    }
  },
  "$defs": {
    "material": {
      "type": "object",
      "required": ["id", "name", "youngs_modulus"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "youngs_modulus": { "type": "number", "exclusiveMinimum": 0 },
        "youngs_modulus_gpa": { "type": "number", "exclusiveMinimum": 0 },
        "poisson_ratio": { "type": ["number", "null"] }
      },
      "anyOf": [
        { "required": ["youngs_modulus"] },
        { "required": ["youngs_modulus_gpa"] }
      ],
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
