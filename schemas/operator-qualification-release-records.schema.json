{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kyuubiki.local/schemas/operator-qualification-release-records.schema.json",
  "title": "Kyuubiki Operator Qualification Release Records",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "release_version", "version_line", "snapshot_path", "records"],
  "properties": {
    "schema_version": { "const": "kyuubiki.operator-qualification-release-records/v1" },
    "release_version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "version_line": { "type": "string", "minLength": 1 },
    "snapshot_path": { "$ref": "#/$defs/repoPath" },
    "records": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/record" } }
  },
  "$defs": {
    "repoPath": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!/)(?![A-Za-z]:)(?!.*\\\\)(?!.*(?:^|/)\\.\\.(?:/|$)).+"
    },
    "makeCommand": {
      "type": "string",
      "pattern": "^make [a-zA-Z0-9_.-]+$"
    },
    "record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "candidate_id",
        "status",
        "evidence_path",
        "capture_command",
        "check_command",
        "review_status",
        "review_gate",
        "promotion_blocker"
      ],
      "properties": {
        "candidate_id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
        "status": { "enum": ["staged_for_review", "attached_to_release", "rejected"] },
        "evidence_path": { "$ref": "#/$defs/repoPath" },
        "capture_command": { "$ref": "#/$defs/makeCommand" },
        "check_command": { "$ref": "#/$defs/makeCommand" },
        "review_status": { "enum": ["pending_signoff", "approved", "blocked_scope", "rejected"] },
        "review_gate": { "type": "string", "minLength": 1 },
        "review_decision_path": { "$ref": "#/$defs/repoPath" },
        "promotion_blocker": { "type": "string", "minLength": 1 }
      }
    }
  }
}
