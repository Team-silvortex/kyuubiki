{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "kyuubiki.material-candidate-materialization-plan.schema.json",
  "title": "Kyuubiki material candidate materialization plan",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "source_request_schema_version",
    "required_result_schema",
    "materialized_candidate_count",
    "materialized_candidates",
    "status"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "schema_version": {
      "const": "kyuubiki.material-candidate-materialization-plan/v1"
    },
    "source_request_schema_version": {
      "type": "string",
      "minLength": 1
    },
    "required_result_schema": {
      "type": "string",
      "minLength": 1
    },
    "materialized_candidate_count": {
      "type": "integer",
      "minimum": 1
    },
    "materialized_candidates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/materializedCandidate"
      }
    },
    "status": {
      "const": "ready_for_solver_rerun"
    }
  },
  "$defs": {
    "materializedCandidate": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "schema_version",
        "candidate_id",
        "source_draft_id",
        "source_candidate_id",
        "strategy",
        "study",
        "required_result_schema",
        "status"
      ],
      "properties": {
        "schema_version": {
          "const": "kyuubiki.materialized-candidate-spec/v1"
        },
        "candidate_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 160
        },
        "source_draft_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 160
        },
        "source_candidate_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 160
        },
        "strategy": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "study": {
          "type": "string",
          "minLength": 1,
          "maxLength": 160
        },
        "required_result_schema": {
          "type": "string",
          "minLength": 1
        },
        "changes": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "expected_effects": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "status": {
          "const": "requires_solver_rerun"
        }
      }
    }
  }
}
