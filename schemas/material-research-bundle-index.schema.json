{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kyuubiki.dev/schemas/material-research-bundle-index.schema.json",
  "title": "Kyuubiki Material Research Bundle Index",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "generated_at_utc",
    "bundle_count",
    "studies",
    "winner_changed_in_chain_count",
    "reliability_decision_counts",
    "next_round_decision_counts",
    "validation_priority_counts",
    "bundles"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "schema_version": {
      "const": "kyuubiki.material-research-bundle-index/v1"
    },
    "generated_at_utc": {
      "type": "string",
      "minLength": 1
    },
    "bundle_count": {
      "type": "integer",
      "minimum": 0
    },
    "studies": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "winner_changed_in_chain_count": {
      "type": "integer",
      "minimum": 0
    },
    "reliability_decision_counts": {
      "$ref": "#/$defs/countMap"
    },
    "next_round_decision_counts": {
      "$ref": "#/$defs/countMap"
    },
    "validation_priority_counts": {
      "$ref": "#/$defs/countMap"
    },
    "bundles": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/bundleIndexEntry"
      }
    }
  },
  "$defs": {
    "countMap": {
      "type": "object",
      "additionalProperties": {
        "type": "integer",
        "minimum": 0
      }
    },
    "stringArray": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "bundleIndexEntry": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "study",
        "bundle_id",
        "path",
        "posture",
        "winner_candidate_id",
        "final_winner_candidate_id",
        "winner_changed_in_chain",
        "reliability_decision",
        "next_round_decision",
        "runnable_next_step_count",
        "next_iteration",
        "chain_stop_reason",
        "chain_convergence_state",
        "chain_round_count",
        "chain_trace_round_count",
        "research_candidate_count",
        "primary_metric_ids",
        "metric_objective_count",
        "violated_quality_gate_ids",
        "focus_candidate_ids",
        "validation_posture",
        "external_validation_required",
        "baseline_ref_count",
        "acceptance_criteria_count",
        "candidate_confidence_counts",
        "validation_readiness_decision",
        "validation_readiness_score",
        "validation_blocking_reasons",
        "next_validation_action_count",
        "validation_priority",
        "validation_priority_rank",
        "validation_priority_reasons",
        "profile_study"
      ],
      "properties": {
        "study": {
          "type": "string",
          "minLength": 1
        },
        "bundle_id": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "posture": {
          "const": "screening_research_bundle"
        },
        "winner_candidate_id": {
          "type": "string",
          "minLength": 1
        },
        "final_winner_candidate_id": {
          "type": "string",
          "minLength": 1
        },
        "winner_changed_in_chain": {
          "type": "boolean"
        },
        "reliability_decision": {
          "type": "string",
          "minLength": 1
        },
        "next_round_decision": {
          "type": "string",
          "minLength": 1
        },
        "runnable_next_step_count": {
          "type": "integer",
          "minimum": 0
        },
        "next_iteration": {
          "type": "integer",
          "minimum": 1
        },
        "chain_stop_reason": {
          "type": "string",
          "minLength": 1
        },
        "chain_convergence_state": {
          "type": "string",
          "minLength": 1
        },
        "chain_round_count": {
          "type": "integer",
          "minimum": 1
        },
        "chain_trace_round_count": {
          "type": "integer",
          "minimum": 1
        },
        "research_candidate_count": {
          "type": "integer",
          "minimum": 1
        },
        "primary_metric_ids": {
          "$ref": "#/$defs/stringArray"
        },
        "metric_objective_count": {
          "type": "integer",
          "minimum": 1
        },
        "violated_quality_gate_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "focus_candidate_ids": {
          "$ref": "#/$defs/stringArray"
        },
        "validation_posture": {
          "const": "screening_validation"
        },
        "external_validation_required": {
          "type": "boolean"
        },
        "baseline_ref_count": {
          "type": "integer",
          "minimum": 1
        },
        "acceptance_criteria_count": {
          "type": "integer",
          "minimum": 1
        },
        "candidate_confidence_counts": {
          "$ref": "#/$defs/confidenceCounts"
        },
        "validation_readiness_decision": {
          "const": "screening_only"
        },
        "validation_readiness_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "validation_blocking_reasons": {
          "$ref": "#/$defs/stringArray"
        },
        "next_validation_action_count": {
          "type": "integer",
          "minimum": 1
        },
        "validation_priority": {
          "enum": [
            "p0_validation_repair",
            "p1_validation_repair",
            "p2_validation_followup"
          ]
        },
        "validation_priority_rank": {
          "type": "integer",
          "minimum": 0,
          "maximum": 2
        },
        "validation_priority_reasons": {
          "$ref": "#/$defs/stringArray"
        },
        "profile_study": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "confidenceCounts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["low", "medium", "high", "unknown"],
      "properties": {
        "low": {
          "type": "integer",
          "minimum": 0
        },
        "medium": {
          "type": "integer",
          "minimum": 0
        },
        "high": {
          "type": "integer",
          "minimum": 0
        },
        "unknown": {
          "type": "integer",
          "minimum": 0
        }
      }
    }
  }
}
