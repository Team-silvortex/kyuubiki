{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kyuubiki.dev/schemas/workflow-dataset.schema.json",
  "title": "Kyuubiki workflow dataset contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "id",
    "version",
    "values"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "kyuubiki.workflow-dataset/v1"
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "values": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/valueInfo"
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    }
  },
  "$defs": {
    "schemaRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema",
        "version"
      ],
      "properties": {
        "schema": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "axis": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "label": {
          "type": "string"
        },
        "size": {
          "type": "integer",
          "minimum": 0
        },
        "semantic": {
          "type": "string"
        }
      }
    },
    "shape": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "axes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/axis"
          }
        }
      }
    },
    "encoding": {
      "type": "string",
      "enum": [
        "json",
        "json_lines",
        "f64_le",
        "f32_le",
        "i64_le",
        "i32_le",
        "u8"
      ]
    },
    "valueInfo": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "data_class",
        "element_type",
        "shape"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "data_class": {
          "type": "string",
          "enum": [
            "study_model",
            "result",
            "field",
            "table",
            "report",
            "export",
            "scalar",
            "metadata"
          ]
        },
        "element_type": {
          "type": "string",
          "minLength": 1
        },
        "shape": {
          "$ref": "#/$defs/shape"
        },
        "semantic_type": {
          "type": "string",
          "minLength": 1
        },
        "unit": {
          "type": "string"
        },
        "encoding": {
          "$ref": "#/$defs/encoding"
        },
        "schema_ref": {
          "$ref": "#/$defs/schemaRef"
        }
      }
    }
  }
}
