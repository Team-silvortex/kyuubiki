    "chain_convergence_schema_version": "kyuubiki.material-chain-convergence-assessment/v1",
    "chain_convergence_state": "blocked_by_quality_gates",
    "next_round_optimization_objectives_schema_version": "kyuubiki.material-next-round-optimization-objectives/v1",
